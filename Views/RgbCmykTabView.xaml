<?xml version="1.0" encoding="utf-8"?>
<UserControl
	x:Class="Irozukume.Views.RgbCmykTabView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:controls="using:Irozukume.Controls"
	xmlns:helpers="using:Irozukume.Helpers"
	mc:Ignorable="d">

	<!-- RGB 群と CMYK 群を縦に積む。群の内側は詰め(両群とも共通の SliderSpacing)、群と群の間は離す(外側 Spacing 24)。ドラッグ時のルーペは最前面オーバーレイへ描かれ切り抜かれないため、先頭の R スライダーの上に逃げ場の余白は要らない。 -->
	<StackPanel Spacing="24">
		<StackPanel.Resources>
			<!-- 各行に共通の3列構成(ラベル・スライダー・数値入力)の幅を揃える。ラベル列の幅は全スライダータブ共通の SliderLabelWidth を使う。数値入力欄は ExpandingNumberBox で、普段は値だけを収める ValueRestWidth まで縮め、フォーカス時(スピンボタンのポップアップ時)に ValueWidth まで広げる。縮んだぶんは隣のスライダー列が伸びる。数値入力欄の右には全行で同じ幅(SuffixWidth)の単位スロットを置き、CMYK だけ "%" を入れる。RGB・グレーは空でも同じ幅を確保し、全行の数値欄の左端を一直線に揃える。 -->
			<x:Double x:Key="ValueWidth">120</x:Double>
			<x:Double x:Key="ValueRestWidth">72</x:Double>
			<x:Double x:Key="SuffixWidth">14</x:Double>
		</StackPanel.Resources>

		<!-- RGB 群 (0–255) -->
		<StackPanel Spacing="{StaticResource SliderSpacing}">

			<!-- タブ共通の2次元エディタ領域。RGB・CMYK で1枚だけ出す平面パッド(下記の RGB 用・CMYK 用のどちらか一方)をタブ先頭に置く。どちらも見せ方ピッカー(単位コンボの隣)で選ぶ。パッド無し(レイアウト0)のときは両方畳むため、先頭の R スライダーの上に余白は生じない。 -->

			<!-- RGB 平面の編集エリア。2成分を取った平面パッドと、残る1成分の縦スライダーを一定間隔で横に並べた組を中央寄せにする。RGB の平面を選んだときだけ出す。パッドの一辺はエリアの幅(縦スライダーの幅と間隔を除く)へ正方形でコード側から合わせ、縦スライダーの高さもそれに揃える。下地画像は固定成分(縦バーが司る成分)と色制限に合わせてコードで作り直す。 -->
			<Grid
				x:Name="RgbPadArea"
				Visibility="Collapsed"
				SizeChanged="OnRgbPadAreaSizeChanged">
				<Grid
					HorizontalAlignment="Center"
					VerticalAlignment="Top"
					ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<controls:PlanarPad
						x:Name="RgbPad"
						Grid.Column="0"
						VerticalAlignment="Top">
						<Image x:Name="RgbPlaneImage" Stretch="Fill" />
					</controls:PlanarPad>

					<!-- 切り出した成分(平面の2軸に取らない残り1成分)の縦スライダー。値・背景・名前はレイアウトに応じてコードビハインドで束ね直す。高さはパッドの一辺に揃える。 -->
					<controls:GradientSlider
						x:Name="RgbCutSlider"
						Grid.Column="1"
						Orientation="Vertical"
						VerticalAlignment="Top"
						Minimum="0"
						Maximum="255"
						StepFrequency="1"
						LargeChange="{x:Bind ViewModel.RgbLargeStep, Mode=OneWay}" />
				</Grid>
			</Grid>

			<!-- CMYK 平面の編集エリア。CMY のうち2成分を取った平面パッドと、残る1成分の縦スライダーを横に並べた組を中央寄せにする。CMYK の平面を選んだときだけ出す。墨(K)は平面に載らず、下の K スライダーで動かす。下地画像は固定成分・墨・色制限に合わせてコードで作り直す。 -->
			<Grid
				x:Name="CmykPadArea"
				Visibility="Collapsed"
				SizeChanged="OnCmykPadAreaSizeChanged">
				<Grid
					HorizontalAlignment="Center"
					VerticalAlignment="Top"
					ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<controls:PlanarPad
						x:Name="CmykPad"
						Grid.Column="0"
						VerticalAlignment="Top">
						<Image x:Name="CmykPlaneImage" Stretch="Fill" />
					</controls:PlanarPad>

					<!-- 切り出した成分(平面の2軸に取らない残りの CMY 成分)の縦スライダー。値・背景・名前はレイアウトに応じてコードビハインドで束ね直す。高さはパッドの一辺に揃える。 -->
					<controls:GradientSlider
						x:Name="CmykCutSlider"
						Grid.Column="1"
						Orientation="Vertical"
						VerticalAlignment="Top"
						Minimum="0"
						Maximum="100"
						StepFrequency="1"
						LargeChange="10" />
				</Grid>
			</Grid>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="HintRed"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="R" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Uid="HintRed"
					Grid.Column="1"
					AutomationProperties.Name="R"
					AutomationProperties.AutomationId="RedSlider"
					Minimum="0"
					Maximum="255"
					StepFrequency="1"
					LargeChange="{x:Bind ViewModel.RgbLargeStep, Mode=OneWay}"
					Value="{x:Bind ViewModel.R, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.RedTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						x:Name="RValueBox"
						x:Uid="HintRed"
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="255"
						Tag="R"
						AutomationProperties.Name="R"
						AutomationProperties.AutomationId="RedValueBox"
						ValueChanged="OnRgbValueChanged" />
					<TextBlock Width="{StaticResource SuffixWidth}" />
				</StackPanel>
			</Grid>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="HintGreen"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="G" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Uid="HintGreen"
					Grid.Column="1"
					AutomationProperties.Name="G"
					AutomationProperties.AutomationId="GreenSlider"
					Minimum="0"
					Maximum="255"
					StepFrequency="1"
					LargeChange="{x:Bind ViewModel.RgbLargeStep, Mode=OneWay}"
					Value="{x:Bind ViewModel.G, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.GreenTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						x:Name="GValueBox"
						x:Uid="HintGreen"
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="255"
						Tag="G"
						AutomationProperties.Name="G"
						AutomationProperties.AutomationId="GreenValueBox"
						ValueChanged="OnRgbValueChanged" />
					<TextBlock Width="{StaticResource SuffixWidth}" />
				</StackPanel>
			</Grid>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="HintBlue"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="B" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Uid="HintBlue"
					Grid.Column="1"
					AutomationProperties.Name="B"
					AutomationProperties.AutomationId="BlueSlider"
					Minimum="0"
					Maximum="255"
					StepFrequency="1"
					LargeChange="{x:Bind ViewModel.RgbLargeStep, Mode=OneWay}"
					Value="{x:Bind ViewModel.B, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.BlueTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						x:Name="BValueBox"
						x:Uid="HintBlue"
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="255"
						Tag="B"
						AutomationProperties.Name="B"
						AutomationProperties.AutomationId="BlueValueBox"
						ValueChanged="OnRgbValueChanged" />
					<TextBlock Width="{StaticResource SuffixWidth}" />
				</StackPanel>
			</Grid>

			<!-- RGB の数値表示の単位と、RGB 群の見せ方ピッカー。単位コンボはスライダーの値(常に 0–255)ではなく数値入力欄の見せ方(255 / FF / 1.0)だけを選び、無彩色スライダーも同じ単位(RgbUnitIndex)に従う。見せ方ピッカーは単位コンボの右隣へ左寄せで並べ、ボタン専用の行を作らず、右端のスクロールバーとも干渉させない。スライダー列に揃えるため先頭にラベル幅の空き列を置く。 -->
			<Grid Margin="0,0,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}" />
				<StackPanel
					Grid.Column="1"
					Orientation="Horizontal"
					HorizontalAlignment="Left"
					Spacing="8">
					<ComboBox
						VerticalAlignment="Center"
						x:Uid="RgbTabUnit"
						AutomationProperties.AutomationId="RgbUnitComboBox"
						SelectedIndex="{x:Bind ViewModel.RgbUnitIndex, Mode=TwoWay}">
						<x:String>255</x:String>
						<x:String>FF</x:String>
						<x:String>1.0</x:String>
					</ComboBox>

					<!-- RGB/CMYK 共通の2次元エディタの見せ方を選ぶアイコンボタン。押すとサムネイル付きのフライアウトを開く。アイコン自体が現在の見せ方の縮小見本を兼ねる。パッド無し(線形スライダーのみ)、RGB の平面3種(G×B+R・R×B+G・R×G+B)、CMYK の平面3種(M×Y+C・C×Y+M・C×M+Y)から1つ選び、選んだ1枚をタブ先頭のパッド領域へ出す。単位コンボの隣へ左寄せで並べ、ボタン専用の行を作らず右端のスクロールバーとも干渉させない。 -->
					<Button
						x:Name="PadLayoutPickerButton"
						VerticalAlignment="Center"
						Padding="4"
						Width="36"
						Height="36"
						x:Uid="PadLayoutPicker">
						<Image
							x:Name="PadLayoutPickerIcon"
							Width="24"
							Height="24"
							Stretch="Fill" />
						<Button.Flyout>
							<Flyout x:Name="PadLayoutPickerFlyout" Opening="OnPadLayoutFlyoutOpening">
								<StackPanel Spacing="8">
									<!-- パッド無し(線形スライダーのみ)。 -->
									<Button Click="OnPickSlidersLayout" Padding="6" HorizontalAlignment="Left" x:Uid="PadLayoutSliders">
										<StackPanel Spacing="4" Width="84">
											<Border x:Name="LayoutSlidersThumbBorder" BorderThickness="2" CornerRadius="4" Padding="4" HorizontalAlignment="Center">
												<Image x:Name="LayoutSlidersThumbImage" Width="56" Height="56" Stretch="Fill" />
											</Border>
											<TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" x:Uid="PadLayoutSlidersCaption" />
										</StackPanel>
									</Button>

									<!-- RGB の平面3種。見出しの RGB は言語非依存のため直接書く。 -->
									<TextBlock Text="RGB" Style="{StaticResource CaptionTextBlockStyle}" />
									<StackPanel Orientation="Horizontal" Spacing="8">
										<Button Click="OnPickRgbGbLayout" Padding="6" x:Uid="RgbLayoutGbPlane">
											<StackPanel Spacing="4" Width="84">
												<Border x:Name="LayoutRgbGbThumbBorder" BorderThickness="2" CornerRadius="4" Padding="4" HorizontalAlignment="Center">
													<Image x:Name="LayoutRgbGbThumbImage" Width="56" Height="56" Stretch="Fill" />
												</Border>
												<TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" x:Uid="RgbLayoutGbPlaneCaption" />
											</StackPanel>
										</Button>

										<Button Click="OnPickRgbRbLayout" Padding="6" x:Uid="RgbLayoutRbPlane">
											<StackPanel Spacing="4" Width="84">
												<Border x:Name="LayoutRgbRbThumbBorder" BorderThickness="2" CornerRadius="4" Padding="4" HorizontalAlignment="Center">
													<Image x:Name="LayoutRgbRbThumbImage" Width="56" Height="56" Stretch="Fill" />
												</Border>
												<TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" x:Uid="RgbLayoutRbPlaneCaption" />
											</StackPanel>
										</Button>

										<Button Click="OnPickRgbRgLayout" Padding="6" x:Uid="RgbLayoutRgPlane">
											<StackPanel Spacing="4" Width="84">
												<Border x:Name="LayoutRgbRgThumbBorder" BorderThickness="2" CornerRadius="4" Padding="4" HorizontalAlignment="Center">
													<Image x:Name="LayoutRgbRgThumbImage" Width="56" Height="56" Stretch="Fill" />
												</Border>
												<TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" x:Uid="RgbLayoutRgPlaneCaption" />
											</StackPanel>
										</Button>
									</StackPanel>

									<!-- CMYK の平面3種。見出しの CMYK は言語非依存のため直接書く。墨(K)は平面に載らず下の K スライダーで動かす。 -->
									<TextBlock Text="CMYK" Style="{StaticResource CaptionTextBlockStyle}" />
									<StackPanel Orientation="Horizontal" Spacing="8">
										<Button Click="OnPickCmykMyLayout" Padding="6" x:Uid="CmykLayoutMyPlane">
											<StackPanel Spacing="4" Width="84">
												<Border x:Name="LayoutCmykMyThumbBorder" BorderThickness="2" CornerRadius="4" Padding="4" HorizontalAlignment="Center">
													<Image x:Name="LayoutCmykMyThumbImage" Width="56" Height="56" Stretch="Fill" />
												</Border>
												<TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" x:Uid="CmykLayoutMyPlaneCaption" />
											</StackPanel>
										</Button>

										<Button Click="OnPickCmykCyLayout" Padding="6" x:Uid="CmykLayoutCyPlane">
											<StackPanel Spacing="4" Width="84">
												<Border x:Name="LayoutCmykCyThumbBorder" BorderThickness="2" CornerRadius="4" Padding="4" HorizontalAlignment="Center">
													<Image x:Name="LayoutCmykCyThumbImage" Width="56" Height="56" Stretch="Fill" />
												</Border>
												<TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" x:Uid="CmykLayoutCyPlaneCaption" />
											</StackPanel>
										</Button>

										<Button Click="OnPickCmykCmLayout" Padding="6" x:Uid="CmykLayoutCmPlane">
											<StackPanel Spacing="4" Width="84">
												<Border x:Name="LayoutCmykCmThumbBorder" BorderThickness="2" CornerRadius="4" Padding="4" HorizontalAlignment="Center">
													<Image x:Name="LayoutCmykCmThumbImage" Width="56" Height="56" Stretch="Fill" />
												</Border>
												<TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" x:Uid="CmykLayoutCmPlaneCaption" />
											</StackPanel>
										</Button>
									</StackPanel>
								</StackPanel>
							</Flyout>
						</Button.Flyout>
					</Button>
				</StackPanel>
			</Grid>
		</StackPanel>

		<!-- CMYK 群 (0–100%)。2次元エディタはタブ先頭の共通領域へ集約したため、この群はスライダーだけを並べる。 -->
		<StackPanel Spacing="{StaticResource SliderSpacing}">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="HintCyan"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="C" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Uid="HintCyan"
					Grid.Column="1"
					AutomationProperties.Name="C"
					AutomationProperties.AutomationId="CyanSlider"
					Minimum="0"
					Maximum="100"
					StepFrequency="1"
					LargeChange="10"
					Value="{x:Bind ViewModel.C, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.CyanTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="100"
						NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
						x:Uid="HintCyan"
						AutomationProperties.Name="C"
						AutomationProperties.AutomationId="CyanValueBox"
						Value="{x:Bind ViewModel.C, Mode=TwoWay}" />
					<TextBlock Text="%" Width="{StaticResource SuffixWidth}" VerticalAlignment="Center" />
				</StackPanel>
			</Grid>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="HintMagenta"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="M" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Uid="HintMagenta"
					Grid.Column="1"
					AutomationProperties.Name="M"
					AutomationProperties.AutomationId="MagentaSlider"
					Minimum="0"
					Maximum="100"
					StepFrequency="1"
					LargeChange="10"
					Value="{x:Bind ViewModel.M, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.MagentaTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="100"
						NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
						x:Uid="HintMagenta"
						AutomationProperties.Name="M"
						AutomationProperties.AutomationId="MagentaValueBox"
						Value="{x:Bind ViewModel.M, Mode=TwoWay}" />
					<TextBlock Text="%" Width="{StaticResource SuffixWidth}" VerticalAlignment="Center" />
				</StackPanel>
			</Grid>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="HintYellow"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="Y" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Uid="HintYellow"
					Grid.Column="1"
					AutomationProperties.Name="Y"
					AutomationProperties.AutomationId="YellowSlider"
					Minimum="0"
					Maximum="100"
					StepFrequency="1"
					LargeChange="10"
					Value="{x:Bind ViewModel.Y, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.YellowTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="100"
						NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
						x:Uid="HintYellow"
						AutomationProperties.Name="Y"
						AutomationProperties.AutomationId="YellowValueBox"
						Value="{x:Bind ViewModel.Y, Mode=TwoWay}" />
					<TextBlock Text="%" Width="{StaticResource SuffixWidth}" VerticalAlignment="Center" />
				</StackPanel>
			</Grid>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="HintKey"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="K" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Uid="HintKey"
					Grid.Column="1"
					AutomationProperties.Name="K"
					AutomationProperties.AutomationId="KeySlider"
					Minimum="0"
					Maximum="100"
					StepFrequency="1"
					LargeChange="10"
					Value="{x:Bind ViewModel.K, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.KeyTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="100"
						NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
						x:Uid="HintKey"
						AutomationProperties.Name="K"
						AutomationProperties.AutomationId="KeyValueBox"
						Value="{x:Bind ViewModel.K, Mode=TwoWay}" />
					<TextBlock Text="%" Width="{StaticResource SuffixWidth}" VerticalAlignment="Center" />
				</StackPanel>
			</Grid>
		</StackPanel>

		<!-- 無彩色(灰)群。R=G=B を同値へ揃える1本。R・G・B・C・M・Y・K と違い、動かすと R・G・B が連動するマクロのため、独立して動かせるチャンネルの群とは分けて区別する(K のノリで掴むと全要素が動く取り違えを避ける)。値は 0–255 で、上の RGB 単位コンボ(RgbUnitIndex)に従う。ラベルは緑と同じ G を使う(無彩色に固有の1文字が無いため)が、スライダーが黒→白のグレーランプである点と、ツールチップ(グレー)で緑と見分けられる。スライダーは現在色の Rec.601 加重輝度を代表位置として示し、つまむまで脱色しない。 -->
		<StackPanel Spacing="{StaticResource SliderSpacing}">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock
					x:Uid="NameGray"
					Grid.Column="0"
					Width="{StaticResource SliderLabelWidth}"
					VerticalAlignment="Center"
					Text="G" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					x:Name="GraySlider"
					Grid.Column="1"
					x:Uid="NameGray"
					AutomationProperties.AutomationId="GraySlider"
					Minimum="0"
					Maximum="255"
					StepFrequency="1"
					LargeChange="{x:Bind ViewModel.RgbLargeStep, Mode=OneWay}"
					ValueChanged="OnGraySliderValueChanged"
					TrackBrush="{x:Bind ViewModel.GrayTrackBrush, Mode=OneWay}" />
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
					<controls:ExpandingNumberBox
						x:Name="GrayValueBox"
						FocusWidth="{StaticResource ValueWidth}"
						RestWidth="{StaticResource ValueRestWidth}"
						VerticalAlignment="Center"
						SpinButtonPlacementMode="Compact"
						Minimum="0"
						Maximum="255"
						Tag="Gray"
						x:Uid="NameGray"
						AutomationProperties.AutomationId="GrayValueBox"
						ValueChanged="OnRgbValueChanged" />
					<TextBlock Width="{StaticResource SuffixWidth}" />
				</StackPanel>
			</Grid>
		</StackPanel>
	</StackPanel>
</UserControl>
