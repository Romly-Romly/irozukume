<?xml version="1.0" encoding="utf-8"?>
<UserControl
	x:Class="Irozukume.Views.PaletteTabView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:controls="using:Irozukume.Controls"
	xmlns:vm="using:Irozukume.ViewModels"
	mc:Ignorable="d">

	<!-- 上段(固定)に操作群、下段(伸縮)に色のリストを置く。操作群はパレット種別の選択・クイック検索・並び順の切替で、コピー／貼り付け履歴を選んだときだけ出所での絞り込みと履歴順を足す。リストは2カラムで、各行はカラーコード(色で塗った背景に映える文字)・警告・色名(履歴では取り込んだ元の文字列)。色帯は市松の上に重ね、履歴の不透明度があれば透けて見える。 -->
	<Grid RowSpacing="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- 操作群。 -->
		<Grid Grid.Row="0" RowSpacing="8">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<!-- パレット種別とクイック検索。検索欄を伸縮させる。 -->
			<Grid ColumnSpacing="8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<!-- パレットの種類。先頭にお気に入り、次に区切り線、その後に組み込みパレット。通常項目は素の文字だけにして標準のコンボと同じ見た目を保ち、区切りだけ専用の線テンプレートにする。区切りは選択できない(IsEnabled=false)。 -->
				<ComboBox
					Grid.Column="0"
					MinWidth="160"
					ItemsSource="{x:Bind ViewModel.ComboItems, Mode=OneWay}"
					SelectedIndex="{x:Bind ViewModel.SelectedComboIndex, Mode=TwoWay}"
					x:Uid="PaletteType">
					<ComboBox.Resources>
						<DataTemplate x:Key="PaletteComboNormalTemplate" x:DataType="vm:PaletteComboItem">
							<TextBlock Text="{x:Bind Name}" />
						</DataTemplate>
						<DataTemplate x:Key="PaletteComboSeparatorTemplate">
							<Border
								Height="1"
								Margin="0,4"
								VerticalAlignment="Center"
								Background="{ThemeResource DividerStrokeColorDefaultBrush}"
								IsHitTestVisible="False" />
						</DataTemplate>
					</ComboBox.Resources>
					<ComboBox.ItemContainerStyle>
						<Style TargetType="ComboBoxItem" BasedOn="{StaticResource DefaultComboBoxItemStyle}">
							<Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
						</Style>
					</ComboBox.ItemContainerStyle>
					<ComboBox.ItemTemplateSelector>
						<controls:PaletteComboItemTemplateSelector
							Item="{StaticResource PaletteComboNormalTemplate}"
							Separator="{StaticResource PaletteComboSeparatorTemplate}" />
					</ComboBox.ItemTemplateSelector>
				</ComboBox>
				<AutoSuggestBox
					Grid.Column="1"
					QueryIcon="Find"
					x:Uid="PaletteSearch"
					TextChanged="OnSearchTextChanged" />
			</Grid>

			<!-- 並び順の切替(左)と、履歴パレット専用の出所フィルタ(右)。履歴順ラジオとフィルタは履歴選択時だけ現れる。 -->
			<Grid Grid.Row="1" ColumnSpacing="12">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<StackPanel
					Orientation="Horizontal"
					Spacing="8"
					VerticalAlignment="Center"
					Visibility="{x:Bind ViewModel.SortVisibility, Mode=OneWay}">
					<TextBlock
						x:Uid="PaletteSortLabel"
						VerticalAlignment="Center"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					<RadioButton
						x:Name="SortHueRadio"
						x:Uid="PaletteSortHue"
						Tag="hue"
						GroupName="PaletteSort"
						MinWidth="0"
						IsChecked="True"
						Checked="OnSortChanged" />
					<RadioButton
						x:Name="SortNameRadio"
						x:Uid="PaletteSortName"
						Tag="name"
						GroupName="PaletteSort"
						MinWidth="0"
						Checked="OnSortChanged" />
					<RadioButton
						x:Name="SortHistoryRadio"
						x:Uid="PaletteSortHistory"
						Tag="history"
						GroupName="PaletteSort"
						MinWidth="0"
						Visibility="{x:Bind ViewModel.HistoryControlsVisibility, Mode=OneWay}"
						Checked="OnSortChanged" />
				</StackPanel>

				<!-- 履歴の出所(すべて/貼り付け/コピー)での絞り込み。履歴選択時だけ現れる。 -->
				<ComboBox
					Grid.Column="1"
					MinWidth="140"
					VerticalAlignment="Center"
					Visibility="{x:Bind ViewModel.HistoryControlsVisibility, Mode=OneWay}"
					ItemsSource="{x:Bind ViewModel.HistoryFilterNames}"
					SelectedIndex="{x:Bind ViewModel.HistoryFilterIndex, Mode=TwoWay}"
					x:Uid="HistoryFilter" />
			</Grid>
		</Grid>

		<!-- 色のリスト・お気に入りのリスト・各種の空案内を重ねて置く。お気に入りを選んだときはスウォッチのリストを隠し、お気に入りのリストを見せる。 -->
		<Grid Grid.Row="1">
			<!-- 色のリスト: 1行1色を縦に積む。各行はカラーコード列と色名列の2カラム構成。クリックで色1に設定する。お気に入りを選んだときは隠す。 -->
			<ScrollViewer
				Visibility="{x:Bind ViewModel.SwatchListVisibility, Mode=OneWay}"
				VerticalScrollBarVisibility="Auto"
				HorizontalScrollMode="Disabled"
				HorizontalScrollBarVisibility="Disabled">
				<ItemsRepeater ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">
					<ItemsRepeater.Layout>
						<StackLayout Spacing="4" />
					</ItemsRepeater.Layout>
					<ItemsRepeater.ItemTemplate>
						<DataTemplate x:DataType="vm:PaletteSwatch">
							<!-- ItemsRepeater は x:Bind テンプレートの行要素へ DataContext を流し込まず、item を直接束縛へ渡す。クリック時に行の色を取り出せるよう、スウォッチ自身を Tag に束縛しておく。 -->
							<Button
								Click="OnSwatchClick"
								Tag="{x:Bind}"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Stretch"
								Background="Transparent"
								BorderThickness="0"
								Padding="0"
								ToolTipService.ToolTip="{x:Bind Name}"
								AutomationProperties.Name="{x:Bind AccessibleName, Mode=OneWay}">
								<Grid Height="40" ColumnSpacing="12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="3*" />
										<ColumnDefinition Width="2*" />
									</Grid.ColumnDefinitions>

									<!-- 色帯: 市松の上にこの色(不透明度つき)を重ね、映える前景色で16進を描く。16進のすぐ右に、現在の色制限で表せないことを示す警告を置く。Border の CornerRadius は内側の塗りを切り抜かないため、市松と色帯それぞれを枠と同じ半径で丸めて角を揃える。 -->
									<Border
										Grid.Column="0"
										BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
										BorderThickness="1"
										CornerRadius="4">
										<Grid>
											<controls:CheckerboardPanel CornerRadius="4" />
											<Border Background="{x:Bind SwatchBrush}" CornerRadius="4" />
											<StackPanel
												Orientation="Horizontal"
												Spacing="8"
												Margin="12,0"
												VerticalAlignment="Center">
												<TextBlock
													VerticalAlignment="Center"
													FontFamily="Consolas"
													FontSize="14"
													Foreground="{x:Bind ForegroundBrush}"
													Text="{x:Bind HexText}" />

												<!-- 色制限中、この色がそのモードで表せなければ警告を出す。黄色い三角に黒縁・黒い「!」を重ねた図形で、Segoe には塗り・輪郭のペアが無い警告三角を自前で合成する。黒縁により、下地がどの色でも埋もれない。 -->
												<Grid
													Width="18"
													Height="18"
													Visibility="{x:Bind WarningVisibility, Mode=OneWay}"
													ToolTipService.ToolTip="{x:Bind WarningTooltip}"
													AutomationProperties.AccessibilityView="Raw"
													VerticalAlignment="Center">
													<Path
														Fill="#FFC107"
														Stroke="#FF000000"
														StrokeThickness="1.2"
														StrokeLineJoin="Round"
														Data="M9,2 L16.5,15.5 L1.5,15.5 Z" />
													<TextBlock
														Text="!"
														FontFamily="Segoe UI"
														FontWeight="Bold"
														FontSize="10"
														Foreground="#FF000000"
														HorizontalAlignment="Center"
														VerticalAlignment="Center"
														Margin="0,2,0,0" />
												</Grid>
											</StackPanel>
										</Grid>
									</Border>

									<!-- 中立背景の名前列(履歴では取り込んだ元の文字列)。履歴の色には出所(貼り付け・コピー・画面ピック)を示すアイコンを名前の左へ添える。アイコンは Auto 幅の列に置き、固定パレットの色では非表示にしてその列を 0 幅へ畳むため、名前の開始位置は変わらない。 -->
									<Grid Grid.Column="1" VerticalAlignment="Center">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>
										<FontIcon
											Grid.Column="0"
											FontSize="14"
											Glyph="{x:Bind KindGlyph}"
											Visibility="{x:Bind KindIconVisibility}"
											Foreground="{ThemeResource TextFillColorSecondaryBrush}"
											Margin="0,0,8,0"
											VerticalAlignment="Center"
											AutomationProperties.AccessibilityView="Raw" />
										<TextBlock
											Grid.Column="1"
											Text="{x:Bind Name}"
											VerticalAlignment="Center"
											TextTrimming="CharacterEllipsis" />
									</Grid>
								</Grid>
							</Button>
						</DataTemplate>
					</ItemsRepeater.ItemTemplate>
				</ItemsRepeater>
			</ScrollViewer>

			<!-- お気に入りのリスト: 1行=1お気に入り。単クリックで行を選択(フォーカス)、ダブルクリックでパレットを復元、選択して DEL で削除・F2 で名前変更。色の升はクリックで一色つまみ食い、右クリックで復元・名前変更・削除のメニュー。お気に入りを選んだときだけ見せる。選択・フォーカス・キー操作のため ListView を使う。 -->
			<ListView
				x:Name="FavoritesList"
				Visibility="{x:Bind ViewModel.FavoritesListVisibility, Mode=OneWay}"
				ItemsSource="{x:Bind ViewModel.FavoriteRows, Mode=OneWay}"
				SelectionMode="Single"
				ContainerContentChanging="OnFavoriteContainerChanging"
				DoubleTapped="OnFavoritesDoubleTapped"
				KeyDown="OnFavoritesKeyDown">
				<ListView.ItemContainerStyle>
					<Style TargetType="ListViewItem">
						<Setter Property="HorizontalContentAlignment" Value="Stretch" />
						<Setter Property="Padding" Value="8,0" />
					</Style>
				</ListView.ItemContainerStyle>
				<ListView.ItemTemplate>
					<DataTemplate x:DataType="vm:FavoriteRowViewModel">
						<!-- 行全体を右クリックの宛先にする。Tag に行自身を束縛し、右クリックメニューの構築で取り出す。背景を透明にして余白部分でもヒットするようにする。色列は他のリストと同じ 3:2 の比率で取り、色の升は色数ぶんの等分で帯いっぱいに敷く。升は色数が可変のため XAML では組めず、ContainerContentChanging で行ごとに組む。 -->
						<Grid
							Height="44"
							ColumnSpacing="12"
							Background="Transparent"
							Tag="{x:Bind}"
							RightTapped="OnFavoriteRowRightTapped">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="2*" />
							</Grid.ColumnDefinitions>

							<!-- 色の升の帯。色数ぶんの等分カラムと升を ContainerContentChanging で流し込む。各升はクリックでその色を編集中の色へつまみ食いする。 -->
							<Grid
								Grid.Column="0"
								ColumnSpacing="4" />

							<!-- お気に入りの名前。クリックは行の選択になり、復元はダブルクリックで行う。 -->
							<TextBlock
								Grid.Column="1"
								Text="{x:Bind Name}"
								VerticalAlignment="Center"
								TextTrimming="CharacterEllipsis" />
						</Grid>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>

			<!-- 履歴パレットで履歴が無いときの案内。 -->
			<TextBlock
				Visibility="{x:Bind ViewModel.EmptyHintVisibility, Mode=OneWay}"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Foreground="{ThemeResource TextFillColorSecondaryBrush}"
				TextAlignment="Center"
				x:Uid="HistoryEmpty" />

			<!-- お気に入りが空のときの案内。 -->
			<TextBlock
				Visibility="{x:Bind ViewModel.FavoritesEmptyHintVisibility, Mode=OneWay}"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Foreground="{ThemeResource TextFillColorSecondaryBrush}"
				TextAlignment="Center"
				x:Uid="FavoritesEmpty" />
		</Grid>
	</Grid>
</UserControl>
