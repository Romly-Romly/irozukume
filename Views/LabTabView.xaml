<?xml version="1.0" encoding="utf-8"?>
<UserControl
	x:Class="Irozukume.Views.LabTabView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:controls="using:Irozukume.Controls"
	xmlns:helpers="using:Irozukume.Helpers"
	mc:Ignorable="d">

	<!-- 上段に明度レール・a-b 平面パッド・右の縦並び設定(OKLab/CIE Lab 切替・色域制限トグル)を置き、下段に a・b のスライダーを置く。パッドは横が a(左 −上限→右 +上限)、縦が b(下 −上限→上 +上限)で、sRGB 色域に収まる部分だけを実色で塗り、色域外はハッチで透かして可視化する。スライダーは表色系で上限が変わらないよう 0–1 の正規化値で束縛し、数値入力欄は各表色系の素の尺度で見せる。パッドはエリアの幅と、スライダー群および明度レール直下の数値欄を除いた残りの高さの小さい方へ正方形でコード側から合わせ、ウィンドウに追従して拡縮する。明度レールの高さもパッドに揃える。 -->
	<Grid x:Name="LayoutRoot" RowSpacing="16">
		<Grid.Resources>
			<!-- スライダー行の数値入力欄の幅を揃える。ラベル列の幅は全スライダータブ共通の SliderLabelWidth を使う。a・b の数値入力欄は符号付き表記で先頭に符号が付くため広めにとる。a・b と明度レールの入力欄はどちらも ExpandingNumberBox で、普段は LabRestWidth まで縮め、フォーカス時(スピンボタンのポップアップ時)に LabValueWidth まで広げる。横スライダーでは縮んだぶん隣のスライダー列が、明度レールでは隣の a-b 平面エリアが広がる。 -->
			<x:Double x:Key="LabValueWidth">124</x:Double>
			<x:Double x:Key="LabRestWidth">84</x:Double>
		</Grid.Resources>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- 上段: 明度レール・a-b 平面パッド・右の縦並び設定。 -->
		<Grid Grid.Row="0" ColumnSpacing="16">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<!-- 明度 L の縦レール。高さはコード側でパッドの一辺に揃える。トラックは現在の a・b での明度ランプ(黒→明)、表示できない範囲は色域外ハッチで示す。下に 0–100 の共通尺度の数値入力欄を出す。 -->
			<StackPanel
				x:Name="LightnessPanel"
				Grid.Column="0"
				Spacing="8"
				VerticalAlignment="Top"
				HorizontalAlignment="Center">
				<controls:GradientSlider
					x:Name="LightnessSlider"
					Orientation="Vertical"
					Minimum="0"
					Maximum="1"
					StepFrequency="0.01"
					LargeChange="0.1"
					x:Uid="NameLabLightness"
					AutomationProperties.AutomationId="LabLightnessSlider"
					Value="{x:Bind ViewModel.LabLNorm, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.LabLightnessTrackBrush, Mode=OneWay}"
					OutOfGamutSegments="{x:Bind ViewModel.LabLightnessGamut, Mode=OneWay}"
					OutOfGamutStyle="{x:Bind ViewModel.OutOfRangeStyle, Mode=OneWay}" />
				<controls:ExpandingNumberBox
					x:Name="LightnessValueBox"
					FocusWidth="{StaticResource LabValueWidth}"
					RestWidth="{StaticResource LabRestWidth}"
					HorizontalAlignment="Center"
					SpinButtonPlacementMode="Compact"
					Minimum="0"
					Maximum="100"
					SmallChange="1"
					NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
					x:Uid="NameLabLightness"
					AutomationProperties.AutomationId="LabLightnessValueBox"
					Value="{x:Bind ViewModel.LabL, Mode=TwoWay}" />
			</StackPanel>

			<!-- a-b 平面エリア。利用可能な領域いっぱいに、正方形を保って拡縮する。パッドの実寸はコード側で領域の短辺へ合わせ、画像は実寸と表示倍率に合わせて作り直す。操作は2軸をまとめて二次元で扱う(色域内への半径方向の寄せ)ため、つまみ位置は一方向束縛で受け、操作の反映は ValuesChanged から SetLabPad へ渡す。 -->
			<Grid
				x:Name="PadArea"
				Grid.Column="1"
				SizeChanged="OnPadAreaSizeChanged">
				<controls:PlanarPad
					x:Name="AbPad"
					HorizontalAlignment="Center"
					VerticalAlignment="Top"
					x:Uid="LabAbPad"
					XValue="{x:Bind ViewModel.LabANorm, Mode=OneWay}"
					YValue="{x:Bind ViewModel.LabBNorm, Mode=OneWay}">
					<Image x:Name="PlaneImage" Stretch="Fill" />
				</controls:PlanarPad>
			</Grid>

			<!-- 右: 縦並びで副モード切替と色域制限トグル。パッドの上端に揃える。 -->
			<StackPanel
				Grid.Column="2"
				VerticalAlignment="Top"
				Spacing="16">

				<!-- OKLab と CIE Lab の切り替え。縦並びにする。パッド・スライダーは共通で、明度・a・b の読み方(尺度と知覚均等性)だけが変わる。表記は言語非依存のためそのまま書く。 -->
				<RadioButtons
					x:Name="SpaceSelector"
					MaxColumns="1"
					SelectedIndex="0"
					SelectionChanged="OnSpaceChanged">
					<x:String>OKLab</x:String>
					<x:String>Lab</x:String>
				</RadioButtons>

				<!-- a・b を sRGB 色域へ制限するトグル。オフ(既定)では色域外の値も保ち、表示できない範囲をハッチで示す。ラベルは短く、説明はツールチップに置く。 -->
				<CheckBox
					x:Uid="LabGamutLimit"
					IsChecked="{x:Bind ViewModel.LabGamutLimit, Mode=TwoWay}" />
			</StackPanel>
		</Grid>

		<!-- 下段: a・b のスライダー。a-b 平面パッドと同じ値に束縛し、どちらからでも操作できる。各行はラベル・スライダー・数値入力欄の3列。スライダーは正規化値(0–1、0.5 が 0)、数値入力欄は素の尺度に束縛する。スライダーには色域外区間を渡してハッチで可視化する。この高さを差し引いてパッドの一辺を決めるため、名前で参照する。 -->
		<StackPanel Grid.Row="1" x:Name="SliderHost" Spacing="{StaticResource SliderSpacing}">
			<!-- a 軸。負が緑寄り、正が赤寄り。数値入力欄の範囲は両表色系を覆う ±125 とし、表色系ごとの上限超過は設定時に丸める。書式とスピン刻みは表色系で切り替える。 -->
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Width="{StaticResource SliderLabelWidth}" VerticalAlignment="Center" Text="a" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					Grid.Column="1"
					x:Uid="NameLabA"
					Minimum="0"
					Maximum="1"
					StepFrequency="{x:Bind ViewModel.LabAbNormStep, Mode=OneWay}"
					LargeChange="{x:Bind ViewModel.LabAbNormLargeStep, Mode=OneWay}"
					Value="{x:Bind ViewModel.LabANorm, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.LabATrackBrush, Mode=OneWay}"
					OutOfGamutSegments="{x:Bind ViewModel.LabAGamut, Mode=OneWay}"
					OutOfGamutStyle="{x:Bind ViewModel.OutOfRangeStyle, Mode=OneWay}" />
				<controls:ExpandingNumberBox
					Grid.Column="2"
					FocusWidth="{StaticResource LabValueWidth}"
					RestWidth="{StaticResource LabRestWidth}"
					VerticalAlignment="Center"
					SpinButtonPlacementMode="Compact"
					Minimum="-125"
					Maximum="125"
					SmallChange="{x:Bind ViewModel.LabAbStep, Mode=OneWay}"
					NumberFormatter="{x:Bind ViewModel.LabAbFormatter, Mode=OneWay}"
					x:Uid="NameLabA"
					AutomationProperties.AutomationId="LabAValueBox"
					Value="{x:Bind ViewModel.LabA, Mode=TwoWay}" />
			</Grid>

			<!-- b 軸。負が青寄り、正が黄寄り。範囲・書式は a と同じ。 -->
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Width="{StaticResource SliderLabelWidth}" VerticalAlignment="Center" Text="b" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					Grid.Column="1"
					x:Uid="NameLabB"
					Minimum="0"
					Maximum="1"
					StepFrequency="{x:Bind ViewModel.LabAbNormStep, Mode=OneWay}"
					LargeChange="{x:Bind ViewModel.LabAbNormLargeStep, Mode=OneWay}"
					Value="{x:Bind ViewModel.LabBNorm, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.LabBTrackBrush, Mode=OneWay}"
					OutOfGamutSegments="{x:Bind ViewModel.LabBGamut, Mode=OneWay}"
					OutOfGamutStyle="{x:Bind ViewModel.OutOfRangeStyle, Mode=OneWay}" />
				<controls:ExpandingNumberBox
					Grid.Column="2"
					FocusWidth="{StaticResource LabValueWidth}"
					RestWidth="{StaticResource LabRestWidth}"
					VerticalAlignment="Center"
					SpinButtonPlacementMode="Compact"
					Minimum="-125"
					Maximum="125"
					SmallChange="{x:Bind ViewModel.LabAbStep, Mode=OneWay}"
					NumberFormatter="{x:Bind ViewModel.LabAbFormatter, Mode=OneWay}"
					x:Uid="NameLabB"
					AutomationProperties.AutomationId="LabBValueBox"
					Value="{x:Bind ViewModel.LabB, Mode=TwoWay}" />
			</Grid>
		</StackPanel>
	</Grid>
</UserControl>
