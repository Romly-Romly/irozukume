<?xml version="1.0" encoding="utf-8"?>
<UserControl
	x:Class="Irozukume.Views.AlphaTabView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:controls="using:Irozukume.Controls"
	mc:Ignorable="d">

	<!-- 不透明度スライダーと、その数値表示の単位を選ぶコンボボックスを縦に積む。 -->
	<StackPanel Spacing="4">
		<StackPanel.Resources>
			<!-- 数値入力欄の幅を RGB タブと揃える。ラベル列の幅は全スライダータブ共通の SliderLabelWidth を使う。入力欄は ExpandingNumberBox で、普段は ValueRestWidth まで縮め、フォーカス時(スピンボタンのポップアップ時)に ValueWidth まで広げる。縮んだぶんは隣のスライダー列が伸びる。 -->
			<x:Double x:Key="ValueWidth">120</x:Double>
			<x:Double x:Key="ValueRestWidth">72</x:Double>
		</StackPanel.Resources>

		<!-- 不透明度 A (0–255)。スライダー背面に市松模様を敷き、透明寄りで下地が透ける様子を見せる。数値入力欄は単位コンボの選択(255 / FF / 100% / 1.0)に追従し、範囲・刻み・書式・右の単位記号がコード側で切り替わる。 -->
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock
				Grid.Column="0"
				Width="{StaticResource SliderLabelWidth}"
				VerticalAlignment="Center"
				Text="A" />
			<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
				Grid.Column="1"
				x:Uid="NameOpacity"
				AutomationProperties.AutomationId="AlphaSlider"
				Minimum="0"
				Maximum="255"
				StepFrequency="1"
				LargeChange="{x:Bind ViewModel.AlphaLargeStep, Mode=OneWay}"
				ShowCheckerboard="True"
				Value="{x:Bind ViewModel.Alpha, Mode=TwoWay}"
				TrackBrush="{x:Bind ViewModel.AlphaTrackBrush, Mode=OneWay}" />
			<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
				<controls:ExpandingNumberBox
					x:Name="AlphaValueBox"
					FocusWidth="{StaticResource ValueWidth}"
					RestWidth="{StaticResource ValueRestWidth}"
					SpinButtonPlacementMode="Compact"
					Minimum="0"
					Maximum="255"
					x:Uid="NameOpacity"
					AutomationProperties.AutomationId="AlphaValueBox"
					ValueChanged="OnAlphaValueChanged" />
				<TextBlock x:Name="AlphaUnitSuffix" VerticalAlignment="Center" />
			</StackPanel>
		</Grid>

		<!-- 数値表示の単位。スライダーの値は常に 0–255 で、ここでは数値入力欄の見せ方だけを 255 / FF / 100% / 1.0 から選ぶ。スライダー列に揃えるため先頭にラベル幅の空き列を置く。 -->
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock
				Grid.Column="0"
				Width="{StaticResource SliderLabelWidth}" />
			<ComboBox
				Grid.Column="1"
				HorizontalAlignment="Left"
				x:Uid="AlphaTabUnit"
				SelectedIndex="{x:Bind ViewModel.AlphaUnitIndex, Mode=TwoWay}">
				<x:String>255</x:String>
				<x:String>FF</x:String>
				<x:String>100%</x:String>
				<x:String>1.0</x:String>
			</ComboBox>
		</Grid>
	</StackPanel>
</UserControl>
