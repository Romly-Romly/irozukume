<?xml version="1.0" encoding="utf-8"?>
<UserControl
	x:Class="Irozukume.Views.ImagePaletteTabView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Irozukume.ViewModels"
	mc:Ignorable="d">

	<!-- 上段(固定)に画像のプレビューと、その右の操作ペイン(アルゴリズム選択と焼きなまし法の詳細設定)を横並びに置く。中段(固定)に色数・抽出・保存の操作群、下段(伸縮)に抽出結果のスウォッチ一覧を置く。スウォッチの行はカラーコード(色で塗った背景に映える文字)と、その色が占める割合。色制限が有効のとき、表せない色には警告の三角を出す。 -->
	<Grid RowSpacing="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- 上段: 左にプレビュー、右に操作ペイン。プレビューの高さは操作ペインの高さに合わせ(下限170px)、OnControlPaneSizeChanged で設定する。上段を Auto 行のままプレビューに伸縮させると、読み込んだ画像の縦横比でプレビューが青天井に伸びて下段の結果リストを押し出すため、画像ではなくペインで上段の高さを決める。 -->
		<Grid Grid.Row="0" ColumnSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" MinWidth="160" />
				<ColumnDefinition Width="260" />
			</Grid.ColumnDefinitions>

			<!-- 画像のドロップ領域兼プレビュー。画像をドロップするか「画像を選択」で読み込む。読み込むとプレビューを見せ、案内を畳む。高さは右の操作ペインに合わせて伸び、下限は170px。 -->
			<Border
				x:Name="DropZone"
				Grid.Column="0"
				MinHeight="170"
				AllowDrop="True"
				DragOver="OnDropZoneDragOver"
				Drop="OnDropZoneDrop"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				CornerRadius="8">
				<Grid>
					<Image
						x:Name="PreviewImage"
						Stretch="Uniform"
						Margin="6" />

					<!-- 読み込み前の案内。画像をドロップするか、ボタンで選ぶ。 -->
					<StackPanel
						x:Name="DropHint"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Spacing="10">
						<FontIcon
							Glyph="&#xEB9F;"
							FontSize="28"
							HorizontalAlignment="Center"
							Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						<TextBlock
							x:Uid="ImageTab_DropHint"
							HorizontalAlignment="Center"
							TextAlignment="Center"
							Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						<Button
							x:Uid="ImageTab_PickFile"
							HorizontalAlignment="Center"
							Click="OnPickFileClick" />
					</StackPanel>

					<!-- 画像を閉じる(クリア)。読み込み済みのときだけ右上に出す。押すと案内へ戻り、再びドロップ/選択できる。 -->
					<Button
						x:Uid="ImageTab_CloseImage"
						HorizontalAlignment="Right"
						VerticalAlignment="Top"
						Margin="6"
						Padding="6"
						MinWidth="0"
						MinHeight="0"
						Visibility="{x:Bind ViewModel.CloseButtonVisibility, Mode=OneWay}"
						Click="OnCloseImageClick">
						<FontIcon Glyph="&#xE711;" FontSize="12" />
					</Button>
				</Grid>
			</Border>

			<!-- 操作ペイン: アルゴリズム選択と、焼きなまし法の詳細設定。プレビューと上端を揃え、内容ぶんだけ縦に伸びる。高さが変わるたびにプレビューの高さを合わせ直す。 -->
			<StackPanel
				Grid.Column="1"
				VerticalAlignment="Top"
				Spacing="12"
				SizeChanged="OnControlPaneSizeChanged">
				<!-- アルゴリズム。ラベルを上の行に、コンボを下の行へ縦並びで置く。形式コンボと同じ SelectedValue + Tag 方式で束縛する。 -->
				<StackPanel Spacing="4">
					<TextBlock
						x:Uid="ImageTab_AlgorithmLabel"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					<ComboBox
						HorizontalAlignment="Stretch"
						IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"
						SelectedValue="{x:Bind ViewModel.AlgorithmKey, Mode=TwoWay}"
						SelectedValuePath="Tag">
						<ComboBoxItem Tag="median_cut" x:Uid="ImageTab_AlgoMedianCut" />
						<ComboBoxItem Tag="kmeans" x:Uid="ImageTab_AlgoKMeans" />
						<ComboBoxItem Tag="octree" x:Uid="ImageTab_AlgoOctree" />
						<ComboBoxItem Tag="sa" x:Uid="ImageTab_AlgoSA" />
					</ComboBox>
				</StackPanel>

				<!-- 焼きなまし法の詳細設定。焼きなまし法を選んだときだけ出す。値は共有モデルへ直に束縛し、settings.json へ保存される。 -->
				<StackPanel
					Spacing="12"
					Visibility="{x:Bind ViewModel.SaSettingsVisibility, Mode=OneWay}">
					<TextBlock
						x:Uid="ImageTab_SaSettingsHeader"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

					<CheckBox
						x:Uid="ImageTab_SaSeed"
						IsChecked="{x:Bind ViewModel.Editor.ImageSaSeedFromMedianCut, Mode=TwoWay}" />

					<Grid ColumnSpacing="12" RowSpacing="12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<NumberBox
							Grid.Row="0"
							Grid.Column="0"
							x:Uid="ImageTab_SaIterations"
							Width="120"
							Minimum="500"
							SmallChange="1000"
							LargeChange="5000"
							SpinButtonPlacementMode="Compact"
							Value="{x:Bind ViewModel.Editor.ImageSaIterations, Mode=TwoWay}" />

						<NumberBox
							Grid.Row="0"
							Grid.Column="1"
							x:Uid="ImageTab_SaMove"
							Width="120"
							Minimum="1"
							SmallChange="1"
							LargeChange="5"
							SpinButtonPlacementMode="Compact"
							Value="{x:Bind ViewModel.Editor.ImageSaMove, Mode=TwoWay}" />

						<NumberBox
							x:Name="SaAlphaBox"
							Grid.Row="1"
							Grid.Column="0"
							x:Uid="ImageTab_SaAlpha"
							Width="120"
							Minimum="0.9"
							Maximum="0.99999"
							SmallChange="0.0001"
							LargeChange="0.001"
							SpinButtonPlacementMode="Compact"
							Value="{x:Bind ViewModel.Editor.ImageSaAlpha, Mode=TwoWay}" />

						<NumberBox
							Grid.Row="1"
							Grid.Column="1"
							x:Uid="ImageTab_SaInitialTemp"
							Width="120"
							Minimum="0.01"
							SmallChange="0.1"
							LargeChange="0.5"
							SpinButtonPlacementMode="Compact"
							Value="{x:Bind ViewModel.Editor.ImageSaInitialTempFactor, Mode=TwoWay}" />

						<Grid
							Grid.Row="2"
							Grid.Column="0"
							Width="120">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Slider
								x:Uid="ImageTab_SaSatWeight"
								HorizontalAlignment="Stretch"
								Minimum="0"
								Maximum="8"
								StepFrequency="1"
								SmallChange="1"
								LargeChange="2"
								TickFrequency="1"
								IsThumbToolTipEnabled="False"
								Value="{x:Bind ViewModel.Editor.ImageSaSaturationWeight, Mode=TwoWay}" />
							<TextBlock
								Grid.Column="1"
								Text="{x:Bind ViewModel.Editor.ImageSaSaturationWeight, Mode=OneWay}"
								VerticalAlignment="Bottom"
								Margin="6,0,0,8"
								MinWidth="16"
								TextAlignment="Right"
								FontFamily="Consolas" />
						</Grid>

						<Grid
							Grid.Row="2"
							Grid.Column="1"
							Width="120">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Slider
								x:Uid="ImageTab_SaRareWeight"
								HorizontalAlignment="Stretch"
								Minimum="0"
								Maximum="8"
								StepFrequency="1"
								SmallChange="1"
								LargeChange="2"
								TickFrequency="1"
								IsThumbToolTipEnabled="False"
								Value="{x:Bind ViewModel.Editor.ImageSaRarityWeight, Mode=TwoWay}" />
							<TextBlock
								Grid.Column="1"
								Text="{x:Bind ViewModel.Editor.ImageSaRarityWeight, Mode=OneWay}"
								VerticalAlignment="Bottom"
								Margin="6,0,0,8"
								MinWidth="16"
								TextAlignment="Right"
								FontFamily="Consolas" />
						</Grid>
					</Grid>
				</StackPanel>
			</StackPanel>
		</Grid>

		<!-- 操作群。色数の選択と、抽出・お気に入り保存。 -->
		<Grid Grid.Row="1" ColumnSpacing="16">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<!-- 色数。スライダーで2〜16色。 -->
			<StackPanel
				Grid.Column="0"
				Orientation="Horizontal"
				Spacing="8"
				VerticalAlignment="Center">
				<TextBlock
					x:Uid="ImageTab_ColorCountLabel"
					VerticalAlignment="Center"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
				<Slider
					x:Name="CountSlider"
					Width="130"
					Minimum="2"
					Maximum="16"
					StepFrequency="1"
					SmallChange="1"
					LargeChange="2"
					TickFrequency="1"
					IsThumbToolTipEnabled="False"
					VerticalAlignment="Center"
					IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"
					ValueChanged="OnCountChanged" />
				<TextBlock
					Text="{x:Bind ViewModel.ColorCount, Mode=OneWay}"
					VerticalAlignment="Center"
					MinWidth="20"
					TextAlignment="Right"
					FontFamily="Consolas" />
			</StackPanel>

			<Button
				Grid.Column="2"
				x:Uid="ImageTab_Extract"
				Click="OnExtractClick"
				IsEnabled="{x:Bind ViewModel.CanExtract, Mode=OneWay}" />

			<Button
				Grid.Column="3"
				x:Uid="ImageTab_SaveFavorite"
				Click="OnSaveFavoriteClick"
				IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}" />
		</Grid>

		<!-- 結果。スウォッチ一覧・抽出中の進捗・空案内を重ねて置く。 -->
		<Grid Grid.Row="2">
			<!-- 抽出結果のスウォッチ一覧。1行1色で、左にカラーコード、右にその色が占める割合。クリックで色1へ反映する。 -->
			<ScrollViewer
				Visibility="{x:Bind ViewModel.SwatchListVisibility, Mode=OneWay}"
				VerticalScrollBarVisibility="Auto"
				HorizontalScrollMode="Disabled"
				HorizontalScrollBarVisibility="Disabled">
				<ItemsRepeater ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">
					<ItemsRepeater.Layout>
						<StackLayout Spacing="4" />
					</ItemsRepeater.Layout>
					<ItemsRepeater.ItemTemplate>
						<DataTemplate x:DataType="vm:PaletteSwatch">
							<!-- ItemsRepeater は行要素へ DataContext を流さないため、クリック時に色を取り出せるようスウォッチ自身を Tag に束縛する。 -->
							<Button
								Click="OnSwatchClick"
								Tag="{x:Bind}"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Stretch"
								Background="Transparent"
								BorderThickness="0"
								Padding="0"
								ToolTipService.ToolTip="{x:Bind HexText}"
								AutomationProperties.Name="{x:Bind AccessibleName, Mode=OneWay}">
								<Grid Height="40" ColumnSpacing="12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="3*" />
										<ColumnDefinition Width="2*" />
									</Grid.ColumnDefinitions>

									<!-- 色帯: この色で塗り、映える前景色で16進を描く。色制限で表せないときは警告の三角を添える。 -->
									<Border
										Grid.Column="0"
										Background="{x:Bind SwatchBrush}"
										BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
										BorderThickness="1"
										CornerRadius="4">
										<StackPanel
											Orientation="Horizontal"
											Spacing="8"
											Margin="12,0"
											VerticalAlignment="Center">
											<TextBlock
												VerticalAlignment="Center"
												FontFamily="Consolas"
												FontSize="14"
												Foreground="{x:Bind ForegroundBrush}"
												Text="{x:Bind HexText}" />

											<!-- 色制限中、この色がそのモードで表せなければ警告を出す。黄色い三角に黒縁・黒い「!」を重ね、下地がどの色でも埋もれないようにする。 -->
											<Grid
												Width="18"
												Height="18"
												Visibility="{x:Bind WarningVisibility, Mode=OneWay}"
												ToolTipService.ToolTip="{x:Bind WarningTooltip}"
												AutomationProperties.AccessibilityView="Raw"
												VerticalAlignment="Center">
												<Path
													Fill="#FFC107"
													Stroke="#FF000000"
													StrokeThickness="1.2"
													StrokeLineJoin="Round"
													Data="M9,2 L16.5,15.5 L1.5,15.5 Z" />
												<TextBlock
													Text="!"
													FontFamily="Segoe UI"
													FontWeight="Bold"
													FontSize="10"
													Foreground="#FF000000"
													HorizontalAlignment="Center"
													VerticalAlignment="Center"
													Margin="0,2,0,0" />
											</Grid>
										</StackPanel>
									</Border>

									<!-- その色が占める割合(百分率)。 -->
									<TextBlock
										Grid.Column="1"
										Text="{x:Bind Name}"
										VerticalAlignment="Center"
										Foreground="{ThemeResource TextFillColorSecondaryBrush}"
										TextTrimming="CharacterEllipsis" />
								</Grid>
							</Button>
						</DataTemplate>
					</ItemsRepeater.ItemTemplate>
				</ItemsRepeater>
			</ScrollViewer>

			<!-- 抽出中の進捗。焼きなまし法など重い手法の間に出す。 -->
			<StackPanel
				Visibility="{x:Bind ViewModel.ExtractingVisibility, Mode=OneWay}"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Spacing="12">
				<ProgressRing IsActive="{x:Bind ViewModel.IsExtracting, Mode=OneWay}" Width="36" Height="36" />
				<TextBlock
					x:Uid="ImageTab_Extracting"
					HorizontalAlignment="Center"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
			</StackPanel>

			<!-- 画像を読み込む前の空案内。 -->
			<TextBlock
				x:Uid="ImageTab_EmptyHint"
				Visibility="{x:Bind ViewModel.EmptyHintVisibility, Mode=OneWay}"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				TextAlignment="Center"
				Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
		</Grid>
	</Grid>
</UserControl>
