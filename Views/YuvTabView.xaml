<?xml version="1.0" encoding="utf-8"?>
<UserControl
	x:Class="Irozukume.Views.YuvTabView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:controls="using:Irozukume.Controls"
	xmlns:helpers="using:Irozukume.Helpers"
	mc:Ignorable="d">

	<!-- 上段に輝度レール・色差平面パッド・右の縦並び設定を置き、下段に Cb・Cr スライダーを置く。両行とも内容の高さに収め、内容は上端へ詰めて余白を下に集める。パッドはエリアの幅と、スライダー群および輝度レール直下の数値欄を除いた残りの高さの小さい方へ正方形でコード側から合わせ、ウィンドウに追従して拡縮する。輝度レールの高さもパッドに揃える。 -->
	<Grid x:Name="LayoutRoot" RowSpacing="16">
		<Grid.Resources>
			<!-- スライダー行の数値入力欄の幅を揃える。ラベル列の幅は全スライダータブ共通の SliderLabelWidth を使う。Cb・Cr の数値入力欄は符号付き表記で先頭に符号が付くため少し広くする。Cb・Cr と輝度レールの入力欄はどちらも ExpandingNumberBox で、普段は YuvRestWidth まで縮め、フォーカス時(スピンボタンのポップアップ時)に YuvValueWidth まで広げる。横スライダーでは縮んだぶん隣のスライダー列が、輝度レールでは隣の色差平面エリアが広がる。 -->
			<x:Double x:Key="YuvValueWidth">124</x:Double>
			<x:Double x:Key="YuvRestWidth">84</x:Double>
		</Grid.Resources>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- 上段: 輝度レール・色差平面パッド・右の縦並び設定。 -->
		<Grid Grid.Row="0" ColumnSpacing="16">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<!-- 輝度 Y の縦レール。高さはコード側でパッドの一辺に揃える。トラックは現在の色差での輝度ランプ(黒→明)、下に数値入力欄を出す。輝度は 0–255 で表記の切替に依らないため、入力欄は値へ直接束縛する。 -->
			<StackPanel
				x:Name="LumaPanel"
				Grid.Column="0"
				Spacing="8"
				VerticalAlignment="Top"
				HorizontalAlignment="Center">
				<controls:GradientSlider
					x:Name="LumaSlider"
					Orientation="Vertical"
					Minimum="0"
					Maximum="255"
					StepFrequency="1"
					x:Uid="NameLumaY"
					AutomationProperties.AutomationId="LumaSlider"
					Value="{x:Bind ViewModel.Luma, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.LumaTrackBrush, Mode=OneWay}"
					OutOfGamutSegments="{x:Bind ViewModel.LumaGamut, Mode=OneWay}"
					OutOfGamutStyle="{x:Bind ViewModel.OutOfRangeStyle, Mode=OneWay}" />
				<controls:ExpandingNumberBox
					x:Name="LumaValueBox"
					FocusWidth="{StaticResource YuvValueWidth}"
					RestWidth="{StaticResource YuvRestWidth}"
					HorizontalAlignment="Center"
					SpinButtonPlacementMode="Compact"
					Minimum="0"
					Maximum="255"
					NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
					x:Uid="NameLumaY"
					AutomationProperties.AutomationId="LumaValueBox"
					Value="{x:Bind ViewModel.Luma, Mode=TwoWay}" />
			</StackPanel>

			<!-- 色差平面エリア。利用可能な領域いっぱいに、正方形を保って拡縮する。パッドの実寸はコード側で領域の短辺へ合わせ、画像は実寸と表示倍率に合わせて作り直す。 -->
			<Grid
				x:Name="PadArea"
				Grid.Column="1"
				SizeChanged="OnPadAreaSizeChanged">
				<controls:PlanarPad
					x:Name="CbCrPad"
					HorizontalAlignment="Center"
					VerticalAlignment="Top"
					x:Uid="YuvCbCrPad"
					XValue="{x:Bind ViewModel.Cb01, Mode=OneWay}"
					YValue="{x:Bind ViewModel.Cr01, Mode=OneWay}">
					<Image x:Name="PlaneImage" Stretch="Fill" />
				</controls:PlanarPad>
			</Grid>

			<!-- 右: 縦並びで YCbCr/YUV 切替・係数規格・量子化レンジ。パッドの上端に揃える。 -->
			<StackPanel
				Grid.Column="2"
				VerticalAlignment="Top"
				Spacing="16">

				<!-- YCbCr(0–255 中心 128)と YUV(符号付き 中心 0)の表示切替。縦並びにする。色は変えず数値の読み方だけが変わる。 -->
				<RadioButtons
					x:Name="ModeSelector"
					MaxColumns="1"
					SelectedIndex="0"
					SelectionChanged="OnModeChanged">
					<x:String>YCbCr</x:String>
					<x:String>YUV</x:String>
				</RadioButtons>

				<ComboBox
					x:Uid="YuvStandard"
					SelectedIndex="{x:Bind ViewModel.StandardIndex, Mode=TwoWay}">
					<x:String>BT.601</x:String>
					<x:String>BT.709</x:String>
					<x:String>BT.2020</x:String>
				</ComboBox>

				<CheckBox
					x:Uid="YuvStudioRange"
					IsChecked="{x:Bind ViewModel.UseStudioRange, Mode=TwoWay}" />

				<!-- 色差を sRGB 色域へ制限するトグル。オフ(既定)では色域外の色差も保ち、表示できない範囲を色差平面上にハッチで示す。オンでは色差を色域境界へ寄せ、つまみを縁に沿わせる。ラベルは短く、説明はツールチップに置く。 -->
				<CheckBox
					x:Uid="YuvGamutLimit"
					IsChecked="{x:Bind ViewModel.YuvGamutLimit, Mode=TwoWay}" />
			</StackPanel>
		</Grid>

		<!-- 下段: Cb・Cr スライダー。色差平面パッドと同じ値に束縛し、どちらからでも操作できる。ラベルは YCbCr/YUV 表記に追従し、数値入力欄も表記(YCbCr 0–255 / 符号付き YUV)に合わせて範囲と値をコード側で組み替える。この高さを差し引いて色差平面パッドの一辺を決めるため、名前で参照する。 -->
		<StackPanel Grid.Row="1" x:Name="SliderHost" Spacing="{StaticResource SliderSpacing}">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Width="{StaticResource SliderLabelWidth}" VerticalAlignment="Center" Text="{x:Bind ChromaLabelB(ViewModel.IsSignedMode), Mode=OneWay}" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					Grid.Column="1"
					AutomationProperties.Name="Cb"
					Minimum="0"
					Maximum="1"
					StepFrequency="{x:Bind ViewModel.YuvChromaStep}"
					LargeChange="{x:Bind ViewModel.YuvChromaLargeStep}"
					Value="{x:Bind ViewModel.Cb01, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.CbTrackBrush, Mode=OneWay}"
					OutOfGamutSegments="{x:Bind ViewModel.CbGamut, Mode=OneWay}"
					OutOfGamutStyle="{x:Bind ViewModel.OutOfRangeStyle, Mode=OneWay}" />
				<controls:ExpandingNumberBox
					x:Name="CbValueBox"
					Grid.Column="2"
					FocusWidth="{StaticResource YuvValueWidth}"
					RestWidth="{StaticResource YuvRestWidth}"
					VerticalAlignment="Center"
					SpinButtonPlacementMode="Compact"
					NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
					AutomationProperties.Name="Cb"
					AutomationProperties.AutomationId="CbValueBox"
					ValueChanged="OnCbValueChanged" />
			</Grid>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Width="{StaticResource SliderLabelWidth}" VerticalAlignment="Center" Text="{x:Bind ChromaLabelR(ViewModel.IsSignedMode), Mode=OneWay}" />
				<controls:GradientSlider Margin="{StaticResource SliderRowGap}"
					Grid.Column="1"
					AutomationProperties.Name="Cr"
					Minimum="0"
					Maximum="1"
					StepFrequency="{x:Bind ViewModel.YuvChromaStep}"
					LargeChange="{x:Bind ViewModel.YuvChromaLargeStep}"
					Value="{x:Bind ViewModel.Cr01, Mode=TwoWay}"
					TrackBrush="{x:Bind ViewModel.CrTrackBrush, Mode=OneWay}"
					OutOfGamutSegments="{x:Bind ViewModel.CrGamut, Mode=OneWay}"
					OutOfGamutStyle="{x:Bind ViewModel.OutOfRangeStyle, Mode=OneWay}" />
				<controls:ExpandingNumberBox
					x:Name="CrValueBox"
					Grid.Column="2"
					FocusWidth="{StaticResource YuvValueWidth}"
					RestWidth="{StaticResource YuvRestWidth}"
					VerticalAlignment="Center"
					SpinButtonPlacementMode="Compact"
					NumberFormatter="{x:Bind helpers:NumberFormatters.Integer}"
					AutomationProperties.Name="Cr"
					AutomationProperties.AutomationId="CrValueBox"
					ValueChanged="OnCrValueChanged" />
			</Grid>
		</StackPanel>
	</Grid>
</UserControl>
