<?xml version="1.0" encoding="utf-8"?>
<Window
	x:Class="Irozukume.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:tkcontrols="using:CommunityToolkit.WinUI.Controls"
	xmlns:controls="using:Irozukume.Controls"
	mc:Ignorable="d">

	<Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" KeyboardAcceleratorPlacementMode="Hidden">
		<!-- 編集の「元に戻す」(Ctrl+Z)・「やり直し」(Ctrl+Y)・「コピー」(Ctrl+C)・「貼り付け」(Ctrl+V)、ウィンドウの「閉じる」(Ctrl+W)、文字色と背景色の役の「入れ替え」(X、テキストモード表示中のみ)、「コントラストマトリックス」(Ctrl+M)、表示の「実際の色」(A)・「色制限の解除/復帰」(L)、タブの直接選択(Ctrl+1～Ctrl+9)と循環(Ctrl+Tab / Ctrl+Shift+Tab)を、ウィンドウのどこにフォーカスがあっても受け取れるよう最上位のレイアウトに割り当てる。修飾なしのキー(X・A・L)はテキスト入力中はその入力欄の文字入力に譲る。設定を開く Ctrl+, はコンマに名前付きの VirtualKey が無いためコード側で登録する。 -->
		<Grid.KeyboardAccelerators>
			<KeyboardAccelerator Modifiers="Control" Key="Z" Invoked="OnUndoAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Y" Invoked="OnRedoAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="C" Invoked="OnCopyAccelerator" />
			<KeyboardAccelerator Modifiers="Control,Shift" Key="C" Invoked="OnCopy2Accelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="V" Invoked="OnPasteAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="W" Invoked="OnCloseAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="M" Invoked="OnContrastMatrixAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="D" Invoked="OnAddFavoriteAccelerator" />
			<KeyboardAccelerator Key="X" Invoked="OnSwapRolesAccelerator" />
			<KeyboardAccelerator Key="A" Invoked="OnToggleActualColorAccelerator" />
			<KeyboardAccelerator Key="L" Invoked="OnToggleLimitAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number1" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number2" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number3" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number4" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number5" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number6" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number7" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Number8" Invoked="OnSelectTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control" Key="Tab" Invoked="OnNextTabAccelerator" />
			<KeyboardAccelerator Modifiers="Control,Shift" Key="Tab" Invoked="OnPrevTabAccelerator" />
		</Grid.KeyboardAccelerators>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- タイトルバー一体型のメインメニュー。LeftHeader にアイコンとメニューを左寄せで並べ、タイトル文字列は表示しない。 -->
		<TitleBar x:Name="AppTitleBar">
			<TitleBar.LeftHeader>
				<StackPanel
					Orientation="Horizontal"
					Spacing="8"
					Margin="16,0,0,0"
					VerticalAlignment="Center">
					<!-- アイコンを装飾の無いボタンで包む。TitleBar コントロールは操作可能なコントロールだけを操作領域(パススルー)にするため、素の Image だとドラッグ領域に飲まれてクリックが届かない。ボタンにすればメニュー同様クリックを拾える。 -->
					<Button
						x:Name="TitleBarIcon"
						x:Uid="TitleBarIcon"
						Click="OnTitleBarIconClick"
						Background="Transparent"
						BorderThickness="0"
						Padding="0"
						MinWidth="0"
						MinHeight="0"
						VerticalAlignment="Center">
						<Image
							x:Name="TitleBarIconImage"
							Width="16"
							Height="16" />
					</Button>
					<MenuBar x:Name="AppMenuBar" VerticalAlignment="Center">
						<MenuBarItem x:Uid="MenuFile">
							<!-- 設定ページを開く。実際のキー割り当ては最上位レイアウトの Ctrl+, が担い、ここの表記は見せるだけ。 -->
							<MenuFlyoutItem x:Uid="MenuOpenSettings" Click="OnOpenSettingsClick" KeyboardAcceleratorTextOverride="Ctrl+,">
								<MenuFlyoutItem.Icon>
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE008;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<MenuFlyoutSeparator />
							<!-- アプリは終了させず、ウィンドウをトレイへ退避させる。×ボタンと同じ動作で、トレイ操作で再表示できる。実際のキー割り当ては最上位レイアウトの Ctrl+W が担い、ここの表記は見せるだけ。 -->
							<MenuFlyoutItem x:Uid="MenuClose" Click="OnCloseMenuClick" KeyboardAcceleratorTextOverride="Ctrl+W" />
							<MenuFlyoutItem x:Uid="MenuExit" Click="OnExitMenuClick" />
						</MenuBarItem>
						<MenuBarItem x:Uid="MenuEdit">
							<!-- 直前の色の状態へ一段戻す/やり直す。実際のキー割り当ては最上位レイアウトの Ctrl+Z / Ctrl+Y が担い、ここの表記は見せるだけ。戻せる/やり直せる段が無いときは無効にする。 -->
							<MenuFlyoutItem
								x:Uid="MenuUndo"
								Click="OnUndoMenuClick"
								KeyboardAcceleratorTextOverride="Ctrl+Z"
								IsEnabled="{x:Bind ViewModel.CanUndo, Mode=OneWay}">
								<MenuFlyoutItem.Icon>
									<FontIcon Glyph="&#xE7A7;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<MenuFlyoutItem
								x:Uid="MenuRedo"
								Click="OnRedoMenuClick"
								KeyboardAcceleratorTextOverride="Ctrl+Y"
								IsEnabled="{x:Bind ViewModel.CanRedo, Mode=OneWay}" />
							<MenuFlyoutSeparator />
							<!-- 設定で選んだ既定の形式でアクティブな色をコピーする。キャプションには実際にコピーされる文字列を「コピー - …」の形で出し、アクティブな色・不透明度・既定形式の変化に追従する。実際のキー割り当ては最上位レイアウトの Ctrl+C が担い、ここの表記は見せるだけ。 -->
							<MenuFlyoutItem
								Text="{x:Bind CopyFormats.CopyMenuCaption, Mode=OneWay}"
								Click="OnCopyMenuClick"
								KeyboardAcceleratorTextOverride="Ctrl+C">
								<MenuFlyoutItem.Icon>
									<FontIcon Glyph="&#xE8C8;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<!-- 設定で選んだ2つ目の既定形式でアクティブな色をコピーする。よく使う形式を2つまで切り替えられるようにするための副系統。接頭辞は「コピー」のまま、付く形式で1つ目と区別する。実際のキー割り当ては最上位レイアウトの Ctrl+Shift+C が担い、ここの表記は見せるだけ。 -->
							<MenuFlyoutItem
								Text="{x:Bind CopyFormats.CopyMenuCaption2, Mode=OneWay}"
								Click="OnCopyMenu2Click"
								KeyboardAcceleratorTextOverride="Ctrl+Shift+C">
								<MenuFlyoutItem.Icon>
									<FontIcon Glyph="&#xE8C8;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<!-- 形式を選んでアクティブな色をコピーする。CSS(Web)で使う形式をここへ集める。各項目のキャプションは現在のアクティブな色を実際にコピーする文字列で表示し、色や不透明度の変化に追従する。名前付きカラーはアクティブな色が CSS 名と完全一致したときだけ現れる。 -->
							<MenuFlyoutSubItem x:Uid="MenuCopyFormatWeb">
								<MenuFlyoutItem Tag="hex" Text="{x:Bind CopyFormats.Hex, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="hexa" Text="{x:Bind CopyFormats.HexAlpha, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem Tag="rgb" Text="{x:Bind CopyFormats.Rgb, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="rgba" Text="{x:Bind CopyFormats.Rgba, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="rgb_modern" Text="{x:Bind CopyFormats.RgbModern, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="rgba_modern" Text="{x:Bind CopyFormats.RgbaModern, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="hsl" Text="{x:Bind CopyFormats.Hsl, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="hsla" Text="{x:Bind CopyFormats.Hsla, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="hsl_modern" Text="{x:Bind CopyFormats.HslModern, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="hsla_modern" Text="{x:Bind CopyFormats.HslaModern, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="hwb" Text="{x:Bind CopyFormats.Hwb, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="hwba" Text="{x:Bind CopyFormats.Hwba, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem Tag="oklch" Text="{x:Bind CopyFormats.Oklch, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="oklcha" Text="{x:Bind CopyFormats.Oklcha, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="lch" Text="{x:Bind CopyFormats.Lch, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="lcha" Text="{x:Bind CopyFormats.Lcha, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem Tag="oklab" Text="{x:Bind CopyFormats.Oklab, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="oklaba" Text="{x:Bind CopyFormats.Oklaba, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="lab" Text="{x:Bind CopyFormats.Lab, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="laba" Text="{x:Bind CopyFormats.Laba, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutSeparator Visibility="{x:Bind CopyFormats.NamedColorVisibility, Mode=OneWay}" />
								<MenuFlyoutItem
									Tag="named"
									Text="{x:Bind CopyFormats.NamedColor, Mode=OneWay}"
									Visibility="{x:Bind CopyFormats.NamedColorVisibility, Mode=OneWay}"
									Click="OnCopyFormatClick" />
							</MenuFlyoutSubItem>
							<!-- 形式を選んでアクティブな色をコピーする。CSS(Web)以外の形式を集める。0x のパック値と、ターミナル(ANSI)のエスケープ列を平らに並べる。ターミナルは前景の トゥルーカラー/256/16/8 を並べ、区切りを挟んで背景の同じ4形式を並べる。各項目のキャプションは「ターミナル前景(フルカラー) - …」のように方向と形式名のラベルに続けて実際にコピーされるエスケープ列を見せ、ESC表現・リセット付与・距離計算・参照テーマの設定を反映する。 -->
							<MenuFlyoutSubItem x:Uid="MenuCopyFormat">
								<MenuFlyoutItem Tag="packed" Text="{x:Bind CopyFormats.Packed, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="packeda" Text="{x:Bind CopyFormats.PackedAlpha, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem Tag="term_tc_fg" Text="{x:Bind CopyFormats.TermTrueColorFg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="term_256_fg" Text="{x:Bind CopyFormats.Term256Fg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="term_16_fg" Text="{x:Bind CopyFormats.Term16Fg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="term_8_fg" Text="{x:Bind CopyFormats.Term8Fg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem Tag="term_tc_bg" Text="{x:Bind CopyFormats.TermTrueColorBg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="term_256_bg" Text="{x:Bind CopyFormats.Term256Bg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="term_16_bg" Text="{x:Bind CopyFormats.Term16Bg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutItem Tag="term_8_bg" Text="{x:Bind CopyFormats.Term8Bg, Mode=OneWay}" Click="OnCopyFormatClick" />
								<MenuFlyoutSeparator />
								<!-- 末尾にリセット(ESC[0m)を付けるか。状態は設定に永続化する。 -->
								<ToggleMenuFlyoutItem x:Uid="MenuCopyTermReset" IsChecked="{x:Bind ViewModel.TerminalResetSuffix, Mode=TwoWay}" />
							</MenuFlyoutSubItem>
							<MenuFlyoutSeparator />
							<MenuFlyoutItem
								x:Uid="MenuPaste"
								Click="OnPasteMenuClick"
								KeyboardAcceleratorTextOverride="Ctrl+V">
								<MenuFlyoutItem.Icon>
									<FontIcon Glyph="&#xE77F;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<!-- 貼り付けた色の書式に合わせて、対応するタブ(と HSV/HSL の副モード)へ切り替えるか。状態は設定に永続化する。 -->
							<ToggleMenuFlyoutItem x:Uid="MenuPasteSwitchTab" IsChecked="{x:Bind ViewModel.SwitchTabOnPaste, Mode=TwoWay}" />
						</MenuBarItem>
						<MenuBarItem x:Uid="MenuColor">
							<!-- すべての色の不透明度を最大(255)へ揃えて完全不透明にする。RGB成分は変えず不透明度だけを揃える全色操作で、他の色操作とは種類が異なるため先頭に区切りで分ける。 -->
							<MenuFlyoutItem
								x:Uid="MenuMakeOpaque"
								Click="OnMakeOpaqueMenuClick" />
							<MenuFlyoutSeparator />
							<!-- ランダムは全色を一度に振る。1色ずつの操作は各色パネルの右クリックメニューが担う。完全ランダムは各成分を独立に無作為。明度/彩度/色相を揃えるものは OKLCh でその軸を全色で共有し、残りを色域内で無作為に振る。コントラストを確保してランダムはテキストモードでのみ有効で、文字色・背景色の役が WCAG AA を満たすようにする。 -->
							<MenuFlyoutItem
								x:Uid="MenuRandom"
								Click="OnRandomMenuClick">
								<MenuFlyoutItem.Icon>
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE005;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<MenuFlyoutItem
								x:Uid="MenuRandomLightness"
								Click="OnRandomLightnessMenuClick" />
							<MenuFlyoutItem
								x:Uid="MenuRandomChroma"
								Click="OnRandomChromaMenuClick" />
							<MenuFlyoutItem
								x:Uid="MenuRandomHue"
								Click="OnRandomHueMenuClick" />
							<MenuFlyoutSeparator />
							<!-- ここから下はコントラスト確認(テキストモード)でのみ有効。コントラストを確保してランダムは文字色・背景色の役が WCAG AA を満たすよう振り、白黒は両役を黒と白に固定して確実にコントラストを確保する。 -->
							<MenuFlyoutItem
								x:Uid="MenuRandomContrast"
								Click="OnRandomContrastMenuClick"
								IsEnabled="{x:Bind ViewModel.EffectiveContrastTextMode, Mode=OneWay}" />
							<MenuFlyoutItem
								x:Uid="MenuBlackWhite"
								Click="OnBlackWhiteMenuClick"
								IsEnabled="{x:Bind ViewModel.EffectiveContrastTextMode, Mode=OneWay}" />
							<MenuFlyoutSeparator />
							<!-- 現在のサイドバーの色を1つのお気に入りパレットとして保存する。コマンドバーの「お気に入りに追加」と同じ操作で、Ctrl+D を割り当てる。 -->
							<MenuFlyoutItem
								x:Uid="MenuAddFavorite"
								Click="OnAddFavoriteClick"
								KeyboardAcceleratorTextOverride="Ctrl+D">
								<MenuFlyoutItem.Icon>
									<FontIcon Glyph="&#xE734;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
						</MenuBarItem>
						<!-- 上段は次/前のタブへの循環移動で、Ctrl+Tab・Ctrl+Shift+Tab を見せる。特定タブへ飛ぶ各ショートカット(Ctrl+数字)はタブボタンのツールチップで案内するため、ここには並べない。実際のキー割り当ては最上位レイアウトが担い、ここの表記は見せるだけ。下段は色の見せ方の設定で、サイドバーのテキストモード・スライダー背景を実際の色で描くか・アルファのスライダー領域を表示するか・色覚シミュレーション・色制限(表示レンズ)を並べる。いずれも各色の値は変えず見え方だけを切り替えるため、表示メニューにまとめる。 -->
						<MenuBarItem x:Uid="MenuView">
							<MenuFlyoutItem x:Uid="MenuNextTab" Click="OnNextTabMenuClick" KeyboardAcceleratorTextOverride="Ctrl+Tab" />
							<MenuFlyoutItem x:Uid="MenuPrevTab" Click="OnPrevTabMenuClick" KeyboardAcceleratorTextOverride="Ctrl+Shift+Tab" />
							<MenuFlyoutSeparator />
							<!-- コマンドバーの各ボタンにアイコンの下のキャプション(名前)を表示するか。オフにするとアイコンだけになり横幅を節約できる。畳んでもボタンはツールチップで名前を出す。表示だけの設定で、色や丸めには影響しない。 -->
							<ToggleMenuFlyoutItem
								x:Uid="MenuShowToolbarCaption"
								IsChecked="{x:Bind ViewModel.ShowToolbarCaption, Mode=TwoWay}" />
							<MenuFlyoutSeparator />
							<!-- スライダー背景を現在の色1を反映した実際の色で描くか。設定ページのトグルと同じ値を双方向で参照する。実際のキー割り当ては最上位レイアウトの A が担い、ここの表記は見せるだけ。 -->
							<ToggleMenuFlyoutItem
								x:Uid="MenuShowActualColor"
								KeyboardAcceleratorTextOverride="A"
								IsChecked="{x:Bind ViewModel.ShowActualColor, Mode=TwoWay}" />
							<!-- アルファのスライダー領域(タブの中身の下)を表示するか。ツールバーのトグルと同じ値を双方向で参照する。オンの間は選択中のタブに依らず不透明度スライダーと単位の組が現れる。 -->
							<ToggleMenuFlyoutItem
								x:Uid="MenuShowAlpha"
								IsChecked="{x:Bind ViewModel.ShowAlpha, Mode=TwoWay}">
								<ToggleMenuFlyoutItem.Icon>
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE002;" />
								</ToggleMenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
							<MenuFlyoutSeparator />
							<!-- サイドバーのテキストモード(コントラスト確認)を切り替える。オンの間は色リストを隠して背景色をサイドバー全体に敷き、アクティブ色の文字のテキスト欄とコントラストパネルを載せる。背景に使う2色目が要るため、色が1つしか無い間は無効。ツールバーのトグルと同じ値を双方向で参照する。 -->
							<ToggleMenuFlyoutItem
								x:Uid="MenuShowContrastText"
								IsEnabled="{x:Bind ViewModel.HasMultipleColors, Mode=OneWay}"
								IsChecked="{x:Bind ViewModel.ShowContrastText, Mode=TwoWay}">
								<ToggleMenuFlyoutItem.Icon>
									<SymbolIcon Symbol="Font" />
								</ToggleMenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
							<!-- コントラスト確認で不透明度(アルファ)を反映するか。オンのとき、サンプル文字を文字色の不透明度で背景色へ透かし、コントラスト比もその透けた実効色で測る。オフなら不透明として扱う。 -->
							<ToggleMenuFlyoutItem
								x:Uid="MenuContrastIncludeAlpha"
								IsChecked="{x:Bind ViewModel.ContrastIncludeAlpha, Mode=TwoWay}" />
							<!-- コントラストマトリックスを別ウィンドウで開く。全色×全色の比を、タブで色を編集しながら監視できる。実際のキー割り当ては最上位レイアウトの Ctrl+M が担い、ここの表記は見せるだけ。 -->
							<MenuFlyoutItem
								x:Uid="MenuContrastMatrix"
								Click="OnContrastMatrixMenuClick"
								KeyboardAcceleratorTextOverride="Ctrl+M">
								<MenuFlyoutItem.Icon>
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00C;" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<MenuFlyoutSeparator />
							<!-- 色制限(表示レンズ)。各色の値は変えず、表示の丸めだけを切り替える。「制限しない」は素早く解除できるよう副メニューへ入れず手前に置く。L は「色を制限しない」と直前に選んだ制限モードを往復で切り替える。実際のキー割り当ては最上位レイアウトの L が担い、各項目の "L" 表記は今の状態で L を押したときの移動先にだけ出すよう VM の *Shortcut を束縛する。各制限は VM 側で排他になるため、副メニューを跨いでも同時に複数は選ばれない。 -->
							<RadioMenuFlyoutItem
								x:Uid="MenuLimitNone"
								GroupName="ColorLimit"
								KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitNoneShortcut, Mode=OneWay}"
								IsChecked="{x:Bind ViewModel.IsLimitNone, Mode=TwoWay}" />
							<MenuFlyoutSubItem x:Uid="MenuLimitSubmenu">
								<MenuFlyoutSubItem.Icon>
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00D;" />
								</MenuFlyoutSubItem.Icon>
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitWebSafe"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitWebSafeShortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitWebSafe, Mode=TwoWay}" />
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitRgb565"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitRgb565Shortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitRgb565, Mode=TwoWay}" />
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitRgb555"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitRgb555Shortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitRgb555, Mode=TwoWay}" />
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitRgb444"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitRgb444Shortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitRgb444, Mode=TwoWay}" />
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitRgb332"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitRgb332Shortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitRgb332, Mode=TwoWay}" />
								<MenuFlyoutSeparator />
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitTerm256"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitTerm256Shortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitTerm256, Mode=TwoWay}" />
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitTerm16"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitTerm16Shortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitTerm16, Mode=TwoWay}" />
								<RadioMenuFlyoutItem
									x:Uid="MenuLimitTerm8"
									GroupName="ColorLimit"
									KeyboardAcceleratorTextOverride="{x:Bind ViewModel.LimitTerm8Shortcut, Mode=OneWay}"
									IsChecked="{x:Bind ViewModel.IsLimitTerm8, Mode=TwoWay}" />
							</MenuFlyoutSubItem>
							<MenuFlyoutSeparator />
							<!-- 色覚シミュレーション。オンの型ごとに、サイドバーの各色パネルの下へその色覚での見え方の行を重ねる。型(P型・D型・T型・1色覚)ごとに独立したトグルで、複数を同時に表示できる。弱まりの強さ(severity)は型を跨いで共通で、色相系を表示中はサイドバー下部に強さスライダーが出る。各色の値は変えず見え方の確認だけに使う。頻繁に切り替えるものではないため、副メニューへまとめる。 -->
							<MenuFlyoutSubItem x:Uid="MenuVisionSubmenu">
								<MenuFlyoutSubItem.Icon>
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE001;" />
								</MenuFlyoutSubItem.Icon>
								<ToggleMenuFlyoutItem
									x:Uid="VisionProtan"
									IsChecked="{x:Bind ViewModel.ShowProtan, Mode=TwoWay}">
									<ToggleMenuFlyoutItem.Icon>
										<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00F;" />
									</ToggleMenuFlyoutItem.Icon>
								</ToggleMenuFlyoutItem>
								<ToggleMenuFlyoutItem
									x:Uid="VisionDeutan"
									IsChecked="{x:Bind ViewModel.ShowDeutan, Mode=TwoWay}">
									<ToggleMenuFlyoutItem.Icon>
										<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00E;" />
									</ToggleMenuFlyoutItem.Icon>
								</ToggleMenuFlyoutItem>
								<ToggleMenuFlyoutItem
									x:Uid="VisionTritan"
									IsChecked="{x:Bind ViewModel.ShowTritan, Mode=TwoWay}">
									<ToggleMenuFlyoutItem.Icon>
										<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE010;" />
									</ToggleMenuFlyoutItem.Icon>
								</ToggleMenuFlyoutItem>
								<ToggleMenuFlyoutItem
									x:Uid="VisionMonochromacy"
									IsChecked="{x:Bind ViewModel.ShowMonochromacy, Mode=TwoWay}" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem
									x:Uid="VisionClearAll"
									Click="OnVisionClearAllClick" />
							</MenuFlyoutSubItem>
						</MenuBarItem>
					</MenuBar>
					<!-- 設定ページ表示中だけ出すページ見出し。メニューバーと入れ替えて表示し、タイトルバー左の ← の右に「設定」を並べる。 -->
					<TextBlock
						x:Name="SettingsHeaderText"
						x:Uid="SettingsPageHeader"
						Visibility="Collapsed"
						Margin="8,0,0,0"
						VerticalAlignment="Center" />
				</StackPanel>
			</TitleBar.LeftHeader>
		</TitleBar>

		<!-- 本体: 左に色プレビュー(サイドバー)、右にツールバー・タブ・タブの中身。間にスプリッターを挟み、利用者が境界をドラッグして配分を変えられる。各列に最低幅を課し、潰れて操作できなくなるのを防ぐ。設定を開くと隠し、SettingsFrame を見せる。 -->
		<Grid
			x:Name="MainContent"
			Grid.Row="1"
			Padding="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition x:Name="SidebarColumn" Width="2*" MinWidth="200" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="3*" MinWidth="340" />
			</Grid.ColumnDefinitions>

			<!-- 左列: 通常は色リスト(最大5色)のパネルを縦に積み、アクティブな色だけ他の2倍の高さで見せる。パネルの生成・行の高さ・クリックや並べ替えはコード側(RebuildColorList ほか)が担う。テキストモード(コントラスト確認)の間は色リストを隠し、背景色をサイドバー全体に敷いてアクティブ色の文字のテキスト欄・コントラスト比・コントラストスライダーを載せる。組み替えはコード側の ApplySidebarTextMode が行う。 -->
			<Grid>
				<Grid.RowDefinitions>
					<!-- 上段に色リスト(またはテキストモードの背景色域)、下段に色覚シミュレーションの強さスライダーを置く。スライダーは表示中だけ高さを持つ。 -->
					<RowDefinition Height="*" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>
				<Grid.Resources>
					<!-- コントラスト確認用のテキスト欄。標準の TextBox は枠線・フォーカス下線・フォーカス時の文字色差し替えを持ち、背景色の上にアクティブ色の文字を見せる用途では邪魔になるため、これらを持たない平坦なテンプレートにする。文字色は束縛した Foreground(アクティブ色)を全状態でそのまま使う。 -->
					<Style x:Key="ColorFieldTextBoxStyle" TargetType="TextBox">
						<Setter Property="Background" Value="Transparent" />
						<Setter Property="BorderThickness" Value="0" />
						<Setter Property="Padding" Value="12" />
						<Setter Property="FontSize" Value="20" />
						<Setter Property="TextAlignment" Value="Center" />
						<Setter Property="VerticalContentAlignment" Value="Center" />
						<Setter Property="HorizontalContentAlignment" Value="Stretch" />
						<Setter Property="UseSystemFocusVisuals" Value="False" />
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="TextBox">
									<Grid Background="{TemplateBinding Background}">
										<ScrollViewer
											x:Name="ContentElement"
											Padding="{TemplateBinding Padding}"
											HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
											HorizontalScrollMode="Disabled"
											HorizontalScrollBarVisibility="Disabled"
											VerticalScrollMode="Auto"
											VerticalScrollBarVisibility="Auto"
											IsTabStop="False"
											AutomationProperties.AccessibilityView="Raw"
											ZoomMode="Disabled" />
										<TextBlock
											x:Name="PlaceholderTextContentPresenter"
											Padding="{TemplateBinding Padding}"
											VerticalAlignment="Center"
											Foreground="{ThemeResource TextControlPlaceholderForeground}"
											Text="{TemplateBinding PlaceholderText}"
											TextAlignment="{TemplateBinding TextAlignment}"
											TextWrapping="Wrap"
											IsHitTestVisible="False" />
									</Grid>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</Grid.Resources>

				<!-- 色リスト。各色のパネル(ColorSwatchPanel)と行の高さ(アクティブだけ2倍)はコード側の RebuildColorList が組み立てる。 -->
				<Grid x:Name="ColorListGrid" RowSpacing="3" />

				<!-- テキストモード: 背景色の役の色をサイドバー全体に敷き、左下にその16進表記を映える色で重ねる。上部の役選択で色リストから文字色・背景色を選び、中央のテキスト欄に文字色の文字を載せてコントラストを確かめ、下の操作カードに WCAG コントラスト比・AA/AAA の適合バッジ・コントラストスライダーを見せる。 -->
				<Grid x:Name="Color2Area" Visibility="Collapsed">
					<Border
						x:Uid="SwatchColor2"
						Background="{x:Bind ViewModel.Color2Brush, Mode=OneWay}"
						BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
						BorderThickness="1"
						CornerRadius="8" />

					<Grid Margin="8">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<!-- 上部の役選択。色リストを横並びのチップで2行(文字色・背景色)に見せ、各行から役に就ける1色を選ぶ。役に就いている色のチップだけを横へ広げ、ほかは正方形に畳むことで、通常モードのアクティブ色パネルが他の2倍に広がるのと同じ見せ方に揃える。選択が動くと幅をアニメーションでつなぐ。役に就いている色は映える色の枠で、編集フォーカスの役はさらにアクセント色の太枠で示す。チップの組み立て・幅アニメ・クリック処理は RoleChipBar が担い、状態の反映はコード側(RebuildContrastRolePanel)が行う。どの背景色の上でも読めるよう、アクリルを敷いて背景色から分離させる。 -->
						<Border
							Grid.Row="0"
							Padding="10,8"
							CornerRadius="8"
							Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
							BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
							BorderThickness="1">
							<Grid RowSpacing="6" ColumnSpacing="2">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<!-- 役ラベル兼入れ替えボタン。文字色・背景色のラベルを縦に並べ、間に上下の矢印を置く。この列まるごとがボタンで、クリックで2色の役を入れ替える(色の値は変えず役だけを差し替える)。専用の入れ替えボタン列を別に設けず、ラベル列に兼ねさせることで横幅をチップへ回す。背景透明・枠なしでラベル然とさせ、ホバー時だけ既定の淡い下地で押せると示す。実際のキー割り当ては最上位レイアウトの X が担い、ツールチップの表記は見せるだけ。 -->
								<Button
									x:Uid="SwatchRoleSwap"
									Grid.Row="0"
									Grid.RowSpan="2"
									Grid.Column="0"
									VerticalAlignment="Stretch"
									Padding="6,2"
									Background="Transparent"
									BorderThickness="0"
									Click="OnSwapRolesClick">
									<Grid RowSpacing="2">
										<Grid.RowDefinitions>
											<RowDefinition Height="*" />
											<RowDefinition Height="Auto" />
											<RowDefinition Height="*" />
										</Grid.RowDefinitions>
										<TextBlock
											x:Uid="ContrastTextRoleLabel"
											Grid.Row="0"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											FontSize="12"
											Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
										<!-- 入れ替えを表す上下向きの矢印。横向きの swap 字形を90度回して上下の入れ替えに見せる。ラベル(12)より小さくして控えめにする。 -->
										<FontIcon
											Grid.Row="1"
											Glyph="&#xE8AB;"
											FontSize="10"
											HorizontalAlignment="Center"
											Foreground="{ThemeResource TextFillColorSecondaryBrush}"
											RenderTransformOrigin="0.5,0.5">
											<FontIcon.RenderTransform>
												<RotateTransform Angle="90" />
											</FontIcon.RenderTransform>
										</FontIcon>
										<TextBlock
											x:Uid="ContrastBgRoleLabel"
											Grid.Row="2"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											FontSize="12"
											Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
									</Grid>
								</Button>

								<controls:RoleChipBar x:Name="TextRoleChips" Grid.Row="0" Grid.Column="1" />
								<controls:RoleChipBar x:Name="BgRoleChips" Grid.Row="1" Grid.Column="1" />
							</Grid>
						</Border>

						<!-- 中央のコントラスト確認用テキスト欄。文字色は文字色の役、背景は背景色の役。打った文字がそのまま文字色で表示され、コントラストの見え方を直接確かめられる。 -->
						<TextBox
							x:Name="ContrastSampleTextBox"
							x:Uid="ContrastSampleText"
							Grid.Row="1"
							Style="{StaticResource ColorFieldTextBoxStyle}"
							Margin="0,12,0,12"
							VerticalAlignment="Center"
							Visibility="{x:Bind ViewModel.ContrastTextVisibility, Mode=OneWay}"
							Foreground="{x:Bind ViewModel.ContrastTextBrush, Mode=OneWay}"
							Text="{x:Bind ViewModel.ContrastSampleText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							AcceptsReturn="True"
							TextWrapping="Wrap" />

						<!-- 左下に背景色の16進表記。背景に映える色で重ねる。 -->
						<TextBlock
							Grid.Row="2"
							Margin="4,0"
							HorizontalAlignment="Left"
							FontFamily="Consolas"
							FontSize="16"
							Foreground="{x:Bind ViewModel.Color2ForegroundBrush, Mode=OneWay}"
							Text="{x:Bind ViewModel.Color2HexText, Mode=OneWay}" />

						<!-- 操作カード: コントラスト比・適合バッジ・スライダー。16進表記の下に置く。どの背景色の上でも読めるよう、アクリルを敷いて背景色から分離させる。テキスト欄と一緒に表示/非表示を切り替える。 -->
						<Border
							Grid.Row="3"
							Margin="0,8,0,0"
							Padding="10,6"
							CornerRadius="8"
							Visibility="{x:Bind ViewModel.ContrastTextVisibility, Mode=OneWay}"
							Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
							BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
							BorderThickness="1">
							<StackPanel Spacing="4">
								<!-- アクティブ色(文字)と背景色の WCAG コントラスト比と AA/AAA バッジ。 -->
								<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
									<TextBlock
										VerticalAlignment="Center"
										FontFamily="Consolas"
										FontSize="14"
										Foreground="{ThemeResource TextFillColorPrimaryBrush}"
										Text="{x:Bind ViewModel.ContrastRatioText, Mode=OneWay}" />
									<Border CornerRadius="4" Padding="6,1" Background="{x:Bind ViewModel.ContrastAaBrush, Mode=OneWay}">
										<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White" Text="AA" />
									</Border>
									<Border CornerRadius="4" Padding="6,1" Background="{x:Bind ViewModel.ContrastAaaBrush, Mode=OneWay}">
										<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White" Text="AAA" />
									</Border>
								</StackPanel>

								<!-- コントラストスライダー。中央(0)が背景色と輝度の一致する点で、右へ動かすほど背景色より明るく、左へ動かすほど暗くなり、いずれも端ほどコントラストが上がる。アクティブ色の色相と彩度は保ち、明度だけを動かす。左右の暗/明ラベルで向きを示す。 -->
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<TextBlock
										x:Uid="ContrastDarkLabel"
										Grid.Column="0"
										VerticalAlignment="Center"
										Margin="0,0,8,0"
										FontSize="12"
										Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
									<Slider
										x:Uid="ContrastSlider"
										Grid.Column="1"
										VerticalAlignment="Center"
										Minimum="-1"
										Maximum="1"
										StepFrequency="0.01"
										SmallChange="0.01"
										LargeChange="0.1"
										TickFrequency="1"
										TickPlacement="Outside"
										IsThumbToolTipEnabled="False"
										Value="{x:Bind ViewModel.ContrastSliderValue, Mode=TwoWay}" />
									<TextBlock
										x:Uid="ContrastLightLabel"
										Grid.Column="2"
										VerticalAlignment="Center"
										Margin="8,0,0,0"
										FontSize="12"
										Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
								</Grid>
							</StackPanel>
						</Border>
					</Grid>
				</Grid>

				<!-- 色覚シミュレーションの強さ(severity)スライダー。色相系(P型・D型・T型)のいずれかを表示中だけ出す。0が正常、右へ動かすほど弱まりが強くなり、端で完全な2色覚。P型・D型・T型に共通で効き、コントラストマトリックスのシミュレーションとも値を共有する。1色覚には効かない。 -->
				<Border
					Grid.Row="1"
					Margin="0,8,0,0"
					Padding="10,6"
					CornerRadius="8"
					Visibility="{x:Bind ViewModel.SidebarVisionSeverityVisibility, Mode=OneWay}"
					Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
					BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
					BorderThickness="1">
					<Grid ColumnSpacing="8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<FontIcon
							x:Uid="VisionSeverityIcon"
							Grid.Column="0"
							FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji"
							Glyph="&#xE001;"
							FontSize="16"
							VerticalAlignment="Center"
							Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						<Slider
							x:Uid="VisionSeveritySlider"
							Grid.Column="1"
							VerticalAlignment="Center"
							Minimum="0"
							Maximum="1"
							StepFrequency="0.01"
							SmallChange="0.01"
							LargeChange="0.1"
							IsThumbToolTipEnabled="False"
							Value="{x:Bind ViewModel.VisionSeverity, Mode=TwoWay}" />
						<TextBlock
							Grid.Column="2"
							VerticalAlignment="Center"
							FontFamily="Consolas"
							FontSize="12"
							MinWidth="36"
							TextAlignment="Right"
							Foreground="{ThemeResource TextFillColorSecondaryBrush}"
							Text="{x:Bind ViewModel.VisionSeverityText, Mode=OneWay}" />
					</Grid>
				</Border>
			</Grid>

			<!-- サイドバーと右列の境界。ドラッグで左右の配分を変える。列の MinWidth が下限を担い、これ以上は縮まない。前後に余白を持たせ、両列の間の見た目の隙間も兼ねる。 -->
			<tkcontrols:GridSplitter
				Grid.Column="1"
				Width="12"
				HorizontalAlignment="Center"
				ResizeDirection="Columns"
				ResizeBehavior="PreviousAndNext"
				Background="Transparent"
				x:Uid="SidebarSplitter" />

			<!-- 右列: ツールバー・タブ代わりのボタンリスト・タブの中身を縦に積む。 -->
			<Grid Grid.Column="2" RowSpacing="12">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<!-- ツールバー: 左寄せの操作群と右寄せの操作群を Grid で振り分ける。ボタンの無い余白を右クリックすると、キャプション表示の切替だけを持つメニューを出す。余白のヒットテストは背景を持つこの Border が受け、ボタンは右クリックを自分で処理するため余白だけに反応する。 -->
				<Border
					Grid.Row="0"
					Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
					BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
					BorderThickness="1"
					CornerRadius="8"
					Padding="4">
					<Border.ContextFlyout>
						<MenuFlyout>
							<ToggleMenuFlyoutItem x:Uid="MenuShowToolbarCaption" IsChecked="{x:Bind ViewModel.ShowToolbarCaption, Mode=TwoWay}" />
						</MenuFlyout>
					</Border.ContextFlyout>
					<Grid x:Name="ToolbarContentGrid" SizeChanged="ToolbarContentGrid_SizeChanged">
						<Grid.Resources>
							<ResourceDictionary>
								<!-- ツールバーのボタンのホバー/押下の塗りを差し替える。WinUI 既定のホバー塗り(ControlFillColorSecondary)はカード地色に近い半透明の明色で、カード上のフラットなボタンではコントラストがほぼ無く見えない。ここではテーマごとに明地へ黒・暗地へ白のオーバーレイを当て、ホバーがはっきり分かるようにする。オン(Checked)時のアクセント表示には手を入れない。 -->
								<ResourceDictionary.ThemeDictionaries>
									<ResourceDictionary x:Key="Default">
										<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1AFFFFFF" />
										<SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#28FFFFFF" />
										<SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#1AFFFFFF" />
										<SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#28FFFFFF" />
										<SolidColorBrush x:Key="SplitButtonBackgroundPointerOver" Color="#1AFFFFFF" />
										<SolidColorBrush x:Key="SplitButtonBackgroundPressed" Color="#28FFFFFF" />
									</ResourceDictionary>
									<ResourceDictionary x:Key="Light">
										<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#14000000" />
										<SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#20000000" />
										<SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#14000000" />
										<SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#20000000" />
										<SolidColorBrush x:Key="SplitButtonBackgroundPointerOver" Color="#14000000" />
										<SolidColorBrush x:Key="SplitButtonBackgroundPressed" Color="#20000000" />
									</ResourceDictionary>
									<ResourceDictionary x:Key="HighContrast">
										<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource SystemColorHighlightColor}" />
										<SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{ThemeResource SystemColorHighlightColor}" />
										<SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="{ThemeResource SystemColorHighlightColor}" />
										<SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="{ThemeResource SystemColorHighlightColor}" />
										<SolidColorBrush x:Key="SplitButtonBackgroundPointerOver" Color="{ThemeResource SystemColorHighlightColor}" />
										<SolidColorBrush x:Key="SplitButtonBackgroundPressed" Color="{ThemeResource SystemColorHighlightColor}" />
									</ResourceDictionary>
								</ResourceDictionary.ThemeDictionaries>

								<!-- ツールバー用の平坦なボタン。通常時の背景は透明で、ポインタを乗せた時だけ強調される。 -->
								<Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
									<Setter Property="Background" Value="Transparent" />
									<Setter Property="BorderThickness" Value="0" />
									<Setter Property="Padding" Value="10,6" />
								</Style>
								<!-- 分割ボタン(色制限・色覚)の静止時だけ枠と地色を透明にし、他の平坦なボタンと見た目を揃える。ホバー/押下とオン時のアクセントは別に残す。 -->
								<SolidColorBrush x:Key="SplitButtonBackground" Color="Transparent" />
								<SolidColorBrush x:Key="SplitButtonBorderBrush" Color="Transparent" />
							</ResourceDictionary>
						</Grid.Resources>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<!-- 操作系のボタン群。バー左へ固定し、入り切らない分のオーバーフローには送らない。 -->
						<StackPanel x:Name="ToolbarLeftGroup" Orientation="Horizontal" Spacing="4" SizeChanged="ToolbarGroup_SizeChanged">
							<!-- 画面から色を拾う。スポイトでカーソル位置の色をガラスレンズ越しに見ながら、左クリックで確定・Esc/右クリックで中止する。 -->
							<Button x:Uid="ToolbarPickColorButton" Style="{StaticResource ToolbarButtonStyle}" Click="OnPickScreenColorClick">
								<StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
									<FontIcon Glyph="&#xEF3C;" HorizontalAlignment="Center" />
									<TextBlock x:Uid="ToolbarPickColor" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ToolbarCaptionVisibility, Mode=OneWay}" />
								</StackPanel>
							</Button>
							<ToggleButton
								x:Uid="ToolbarShowTextButton"
								Background="Transparent"
								BorderThickness="0"
								Padding="10,6"
								IsEnabled="{x:Bind ViewModel.HasMultipleColors, Mode=OneWay}"
								IsChecked="{x:Bind ViewModel.ShowContrastText, Mode=TwoWay}">
								<StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
									<SymbolIcon Symbol="Font" HorizontalAlignment="Center" />
									<TextBlock x:Uid="ToolbarShowText" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ToolbarCaptionVisibility, Mode=OneWay}" />
								</StackPanel>
							</ToggleButton>

							<!-- コントラストマトリックスを別ウィンドウで開く。全色×全色の比を、タブで色を編集しながら監視できる。表示メニューの項目と同じハンドラ(Ctrl+M を割り当て済み)を呼ぶ。 -->
							<Button x:Uid="ToolbarMatrixButton" Style="{StaticResource ToolbarButtonStyle}" Click="OnContrastMatrixMenuClick">
								<StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00C;" HorizontalAlignment="Center" />
									<TextBlock x:Uid="ToolbarMatrix" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ToolbarCaptionVisibility, Mode=OneWay}" />
								</StackPanel>
							</Button>

							<!-- 現在のサイドバーの色を1つのお気に入りパレットとして保存する。Palette タブのお気に入りリストに行として並ぶ。 -->
							<Button x:Uid="ToolbarAddFavoriteButton" Style="{StaticResource ToolbarButtonStyle}" Click="OnAddFavoriteClick">
								<StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
									<FontIcon Glyph="&#xE734;" HorizontalAlignment="Center" />
									<TextBlock x:Uid="ToolbarAddFavorite" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ToolbarCaptionVisibility, Mode=OneWay}" />
								</StackPanel>
							</Button>
						</StackPanel>

						<!-- 表示レンズ系のボタン群。右へ寄せ、バーが狭くて収まらないときは右端のものから1つずつ畳み、… ボタンのメニューへ送る(自前の段階的オーバーフロー)。畳む数の判定は幅を測る UpdateToolbarOverflow が行う。 -->
						<StackPanel x:Name="ToolbarRightGroup" Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" SizeChanged="ToolbarGroup_SizeChanged">
							<!-- アルファのスライダー領域(タブの中身の下)の表示を切り替える。表示メニューのトグルと同じ値を双方向で参照する。 -->
							<ToggleButton
								x:Name="InlineAlpha"
								x:Uid="ToolbarShowAlphaButton"
								Background="Transparent"
								BorderThickness="0"
								Padding="10,6"
								IsChecked="{x:Bind ViewModel.ShowAlpha, Mode=TwoWay}">
								<StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE002;" HorizontalAlignment="Center" />
									<TextBlock x:Uid="ToolbarShowAlpha" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ToolbarCaptionVisibility, Mode=OneWay}" />
								</StackPanel>
							</ToggleButton>
							<!-- 色制限(表示レンズ)。ボタン部で制限の解除/復帰を切り替え(オフ→オンは直前のモードへ復帰、無ければ Webセーフ)、▼のメニューでモードを単一選択する。表示メニューの色制限と同じ VM プロパティを双方向で参照する。各色の RGB は変えず表示の丸めだけを切り替える。点灯は制限中かを表す。 -->
							<ToggleSplitButton
								x:Name="InlineLimit"
								x:Uid="ToolbarLimitButton"
								Background="Transparent"
								IsChecked="{x:Bind ViewModel.IsColorLimited, Mode=TwoWay}">
								<StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00D;" HorizontalAlignment="Center" />
									<TextBlock x:Uid="ToolbarLimit" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ToolbarCaptionVisibility, Mode=OneWay}" />
								</StackPanel>
								<ToggleSplitButton.Flyout>
									<MenuFlyout Placement="Bottom">
										<RadioMenuFlyoutItem x:Uid="MenuLimitNone" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitNone, Mode=TwoWay}" />
										<MenuFlyoutSeparator />
										<RadioMenuFlyoutItem x:Uid="MenuLimitWebSafe" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitWebSafe, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb565" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitRgb565, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb555" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitRgb555, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb444" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitRgb444, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb332" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitRgb332, Mode=TwoWay}" />
										<MenuFlyoutSeparator />
										<RadioMenuFlyoutItem x:Uid="MenuLimitTerm256" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitTerm256, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitTerm16" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitTerm16, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitTerm8" GroupName="ColorLimitToolbar" IsChecked="{x:Bind ViewModel.IsLimitTerm8, Mode=TwoWay}" />
									</MenuFlyout>
								</ToggleSplitButton.Flyout>
							</ToggleSplitButton>
							<!-- 色覚シミュレーション。ボタン部で色覚行の表示を一括オン/オフ(オフ→オンは直前の組み合わせへ復元、無ければ D型)、▼のメニューで型(P型・D型・T型・1色覚)を複数選ぶ。表示メニューの副メニューと同じ値を双方向で参照する。点灯はどれか表示中かを表す。 -->
							<ToggleSplitButton
								x:Name="InlineVision"
								x:Uid="ToolbarVisionButton"
								Background="Transparent"
								IsChecked="{x:Bind ViewModel.AnyVisionShown, Mode=TwoWay}">
								<StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center">
									<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE001;" HorizontalAlignment="Center" />
									<TextBlock x:Uid="ToolbarVision" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ToolbarCaptionVisibility, Mode=OneWay}" />
								</StackPanel>
								<ToggleSplitButton.Flyout>
									<MenuFlyout Placement="Bottom">
										<ToggleMenuFlyoutItem x:Uid="VisionProtan" IsChecked="{x:Bind ViewModel.ShowProtan, Mode=TwoWay}">
											<ToggleMenuFlyoutItem.Icon>
												<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00F;" />
											</ToggleMenuFlyoutItem.Icon>
										</ToggleMenuFlyoutItem>
										<ToggleMenuFlyoutItem x:Uid="VisionDeutan" IsChecked="{x:Bind ViewModel.ShowDeutan, Mode=TwoWay}">
											<ToggleMenuFlyoutItem.Icon>
												<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00E;" />
											</ToggleMenuFlyoutItem.Icon>
										</ToggleMenuFlyoutItem>
										<ToggleMenuFlyoutItem x:Uid="VisionTritan" IsChecked="{x:Bind ViewModel.ShowTritan, Mode=TwoWay}">
											<ToggleMenuFlyoutItem.Icon>
												<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE010;" />
											</ToggleMenuFlyoutItem.Icon>
										</ToggleMenuFlyoutItem>
										<ToggleMenuFlyoutItem x:Uid="VisionMonochromacy" IsChecked="{x:Bind ViewModel.ShowMonochromacy, Mode=TwoWay}" />
										<MenuFlyoutSeparator />
										<MenuFlyoutItem x:Uid="VisionClearAll" Click="OnVisionClearAllClick" />
									</MenuFlyout>
								</ToggleSplitButton.Flyout>
							</ToggleSplitButton>
						</StackPanel>

						<!-- オーバーフローの … ボタン。表示レンズのどれかが畳まれている間だけ現れ、畳まれたものだけをメニューに並べて開く。普段は畳んでおく。 -->
						<Button
							x:Name="ToolbarOverflowButton"
							x:Uid="ToolbarOverflowButton"
							Grid.Column="2"
							Visibility="Collapsed"
							Style="{StaticResource ToolbarButtonStyle}">
							<FontIcon Glyph="&#xE712;" />
							<Button.Flyout>
								<MenuFlyout Placement="Bottom">
									<!-- 各表示レンズを1項目ずつ並べる。畳まれた(オーバーフローした)ものだけを UpdateToolbarOverflow が可視にする。1項目=1要素にして個別に出し入れできるようにし、色制限は「制限しない」も含めて副メニューへ畳む。状態は VM の同じプロパティを双方向束縛し、インラインのボタンと一致する。 -->
									<ToggleMenuFlyoutItem x:Name="OverflowAlphaItem" x:Uid="MenuShowAlpha" Visibility="Collapsed" IsChecked="{x:Bind ViewModel.ShowAlpha, Mode=TwoWay}">
										<ToggleMenuFlyoutItem.Icon>
											<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE002;" />
										</ToggleMenuFlyoutItem.Icon>
									</ToggleMenuFlyoutItem>
									<MenuFlyoutSubItem x:Name="OverflowLimitItem" x:Uid="MenuLimitSubmenu" Visibility="Collapsed">
										<MenuFlyoutSubItem.Icon>
											<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00D;" />
										</MenuFlyoutSubItem.Icon>
										<RadioMenuFlyoutItem x:Uid="MenuLimitNone" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitNone, Mode=TwoWay}" />
										<MenuFlyoutSeparator />
										<RadioMenuFlyoutItem x:Uid="MenuLimitWebSafe" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitWebSafe, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb565" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitRgb565, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb555" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitRgb555, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb444" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitRgb444, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitRgb332" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitRgb332, Mode=TwoWay}" />
										<MenuFlyoutSeparator />
										<RadioMenuFlyoutItem x:Uid="MenuLimitTerm256" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitTerm256, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitTerm16" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitTerm16, Mode=TwoWay}" />
										<RadioMenuFlyoutItem x:Uid="MenuLimitTerm8" GroupName="ColorLimitOverflow" IsChecked="{x:Bind ViewModel.IsLimitTerm8, Mode=TwoWay}" />
									</MenuFlyoutSubItem>
									<MenuFlyoutSubItem x:Name="OverflowVisionItem" x:Uid="MenuVisionSubmenu" Visibility="Collapsed">
										<MenuFlyoutSubItem.Icon>
											<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE001;" />
										</MenuFlyoutSubItem.Icon>
										<ToggleMenuFlyoutItem x:Uid="VisionProtan" IsChecked="{x:Bind ViewModel.ShowProtan, Mode=TwoWay}">
											<ToggleMenuFlyoutItem.Icon>
												<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00F;" />
											</ToggleMenuFlyoutItem.Icon>
										</ToggleMenuFlyoutItem>
										<ToggleMenuFlyoutItem x:Uid="VisionDeutan" IsChecked="{x:Bind ViewModel.ShowDeutan, Mode=TwoWay}">
											<ToggleMenuFlyoutItem.Icon>
												<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE00E;" />
											</ToggleMenuFlyoutItem.Icon>
										</ToggleMenuFlyoutItem>
										<ToggleMenuFlyoutItem x:Uid="VisionTritan" IsChecked="{x:Bind ViewModel.ShowTritan, Mode=TwoWay}">
											<ToggleMenuFlyoutItem.Icon>
												<FontIcon FontFamily="ms-appx:///Assets/Fonts/romoji.ttf#Romoji" Glyph="&#xE010;" />
											</ToggleMenuFlyoutItem.Icon>
										</ToggleMenuFlyoutItem>
										<ToggleMenuFlyoutItem x:Uid="VisionMonochromacy" IsChecked="{x:Bind ViewModel.ShowMonochromacy, Mode=TwoWay}" />
										<MenuFlyoutSeparator />
										<MenuFlyoutItem x:Uid="VisionClearAll" Click="OnVisionClearAllClick" />
									</MenuFlyoutSubItem>
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</Grid>
				</Border>

				<!-- タブ代わりのボタンリスト。ウィンドウが狭くタブが収まりきらないとき横スクロールできるよう ScrollViewer で包む。 -->
				<ScrollViewer
					Grid.Row="1"
					HorizontalScrollMode="Enabled"
					HorizontalScrollBarVisibility="Auto"
					VerticalScrollMode="Disabled"
					VerticalScrollBarVisibility="Disabled">
					<SelectorBar
						x:Name="TabSelectorBar"
						Margin="0,-4,0,4"
						SelectionChanged="TabSelectorBar_SelectionChanged">
						<SelectorBar.Resources>
							<!-- タブを擬似アイコン化するための自前テンプレート。既定テンプレートでは文字部の TextAlignment が左寄せで、2行に積んだ略号の短い行が中央に揃わないため、最小構成のテンプレートを与えて文字を中央揃えにする。参照するリソースは解決の確実な標準 ThemeResource のみに絞る。 -->
							<Style TargetType="SelectorBarItem">
								<Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
								<Setter Property="Background" Value="Transparent" />
								<Setter Property="FontSize" Value="11" />
								<Setter Property="Padding" Value="4,6,4,5" />
								<Setter Property="HorizontalAlignment" Value="Left" />
								<Setter Property="VerticalAlignment" Value="Center" />
								<Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
								<!-- 全タブを同じ寸法に揃える。幅を固定して文字数による伸縮をなくし、高さを固定して1行タブと2行タブの背丈を合わせる。 -->
								<Setter Property="Width" Value="54" />
								<Setter Property="Height" Value="40" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="SelectorBarItem">
											<Grid x:Name="PART_ContainerRoot" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" RowDefinitions="*,Auto">
												<VisualStateManager.VisualStateGroups>
													<VisualStateGroup x:Name="CombinedStates">
														<VisualState x:Name="UnselectedNormal" />
														<VisualState x:Name="UnselectedPointerOver">
															<Storyboard>
																<ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_ContainerRoot" Storyboard.TargetProperty="Background">
																	<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
																</ObjectAnimationUsingKeyFrames>
															</Storyboard>
														</VisualState>
														<VisualState x:Name="UnselectedPressed">
															<Storyboard>
																<ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_ContainerRoot" Storyboard.TargetProperty="Background">
																	<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
																</ObjectAnimationUsingKeyFrames>
															</Storyboard>
														</VisualState>
														<VisualState x:Name="SelectedNormal">
															<Storyboard>
																<DoubleAnimation Storyboard.TargetName="PART_SelectionVisual" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.167" />
															</Storyboard>
														</VisualState>
														<VisualState x:Name="SelectedPointerOver">
															<Storyboard>
																<DoubleAnimation Storyboard.TargetName="PART_SelectionVisual" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
																<ObjectAnimationUsingKeyFrames Storyboard.TargetName="PART_ContainerRoot" Storyboard.TargetProperty="Background">
																	<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
																</ObjectAnimationUsingKeyFrames>
															</Storyboard>
														</VisualState>
														<VisualState x:Name="SelectedPressed">
															<Storyboard>
																<DoubleAnimation Storyboard.TargetName="PART_SelectionVisual" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
															</Storyboard>
														</VisualState>
													</VisualStateGroup>
												</VisualStateManager.VisualStateGroups>
												<TextBlock x:Name="PART_TextVisual" Text="{TemplateBinding Text}" FontSize="{TemplateBinding FontSize}" FontFamily="{TemplateBinding FontFamily}" Foreground="{TemplateBinding Foreground}" Margin="{TemplateBinding Padding}" HorizontalAlignment="Stretch" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" LineHeight="13" LineStackingStrategy="BlockLineHeight" />
												<Rectangle x:Name="PART_SelectionVisual" Grid.Row="1" Fill="{ThemeResource AccentFillColorDefaultBrush}" Height="3" Width="16" RadiusX="1.5" RadiusY="1.5" HorizontalAlignment="Center" VerticalAlignment="Bottom" IsHitTestVisible="False" Opacity="0" />
											</Grid>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</SelectorBar.Resources>
						<!-- 色空間タブは略号を2行に積み、擬似アイコン化して横幅を抑える。ツールチップは略号を1行にまとめた正式名にショートカットを添える(言語非依存のためここへ直接書く)。タブへ飛ぶショートカットの案内は、表示メニューから移してこのツールチップへ集約する。 -->
						<SelectorBarItem Tag="rgbcmyk" Text="RGB&#x0A;CMYK" ToolTipService.ToolTip="RGB/CMYK (Ctrl+1)" IsSelected="True" />
						<SelectorBarItem Tag="hsvhsl" Text="HSV&#x0A;HSL" ToolTipService.ToolTip="HSV/HSL/HWB (Ctrl+2)" />
						<SelectorBarItem Tag="lch" Text="LCH&#x0A;OKLCH" ToolTipService.ToolTip="LCH/OKLCH (Ctrl+3)" />
						<SelectorBarItem Tag="lab" Text="Lab&#x0A;OKLab" ToolTipService.ToolTip="Lab/OKLab (Ctrl+4)" />
						<SelectorBarItem Tag="yuvycbcr" Text="YUV&#x0A;YCbCr" ToolTipService.ToolTip="YUV/YCbCr (Ctrl+5)" />
						<SelectorBarItem Tag="palette" x:Uid="TabPalette" />
						<SelectorBarItem Tag="mix" x:Uid="TabMix" />
						<SelectorBarItem Tag="harmony" x:Uid="TabHarmony" />
					</SelectorBar>
				</ScrollViewer>

				<!-- タブの中身と、その下に常駐するアルファのスライダー領域を縦に積む。アルファ領域はトグルがオンのときだけ現れ、隠れている間は高さも上の余白も持たないため、タブの中身が下端まで広がる。 -->
				<Grid Grid.Row="2">
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<!-- タブの中身 -->
					<Border
						Grid.Row="0"
						Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
						BorderThickness="1"
						CornerRadius="8"
						Padding="8,8,8,8">
						<ContentControl
							x:Name="TabContent"
							HorizontalContentAlignment="Stretch"
							VerticalContentAlignment="Stretch" />
					</Border>

					<!-- アルファのスライダー領域。表示メニュー・ツールバーの「アルファ値を表示」がオンのときだけ現れ、選択中のタブに依らず不透明度スライダーと単位の組を見せる。中身の AlphaTabView はコード側で差し込む。隠れている間に余白で隙間が空かないよう、タブの中身との間隔は上マージンで取る。 -->
					<Border
						x:Name="AlphaPanelBorder"
						Grid.Row="1"
						Margin="0,6,0,0"
						Visibility="{x:Bind ViewModel.AlphaPanelVisibility, Mode=OneWay}"
						Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
						BorderThickness="1"
						CornerRadius="8"
						Padding="8" />
				</Grid>
			</Grid>
		</Grid>

		<!-- 設定ページの差し込み先。本体(MainContent)と同じ Row1 に常に重ね、当たり判定の有無で本体表示と設定表示を切り替える。中身(SettingsView)は不透明な薄い宿主ページ(SettingsHostPage)へ載せて Frame でナビゲートし、組み込みの NavigationThemeTransition(フェード＋下からの軽いスライド)で現し、戻る(GoBack)でその逆再生で退ける。退いた先は透明な土台ページ(BackdropPage)で、その間は当たり判定を切って本体へ操作を通す。これらの遷移は OS の「アニメーションを表示する」設定がオフのとき自動で抑制される。 -->
		<Frame
			x:Name="SettingsFrame"
			Grid.Row="1"
			IsHitTestVisible="False" />

		<!-- ドラッグ中の拡大つまみ(ルーペ)を最前面で描くための透明オーバーレイ。タブの中身を包むスクロール領域の内側ではルーペが上下端で切り抜かれるため、レンズの描画コントロールだけをこの層へ移し、どこへはみ出しても切れないようにする。本体・設定ページのどちらの上にも常に重なるよう RootGrid 直下の最後の子に置き、全行を覆う。入力は奪わない。読み込み後にコード側で LensOverlayService へ登録する。 -->
		<Canvas
			x:Name="LensOverlay"
			Grid.Row="0"
			Grid.RowSpan="2"
			IsHitTestVisible="False" />
	</Grid>
</Window>
