<?xml version="1.0" encoding="utf-8"?>
<Application
	x:Class="Irozukume.App"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
				<ResourceDictionary Source="ms-appx:///Controls/GradientSlider.xaml" />
				<ResourceDictionary Source="ms-appx:///Controls/RingSlider.xaml" />
				<ResourceDictionary Source="ms-appx:///Controls/PlanarPad.xaml" />
				<ResourceDictionary Source="ms-appx:///Controls/TrianglePad.xaml" />
			</ResourceDictionary.MergedDictionaries>

			<!-- スライダータブ共通の、群内スライダー間の縦間隔の既定値。全スライダータブがこれを参照し、間隔の調整を一点へ集める。個別に変えたいタブは自分のリソースで同名キーを定義して上書きできる(例: リング系は詰める、2次元パッド直後は広げる)。 -->
			<x:Double x:Key="SliderSpacing">8</x:Double>

			<!-- スライダー行の先頭ラベル列の幅の既定値。全スライダータブがこれを参照し、各行のスライダー左端の位置を揃える。 -->
			<x:Double x:Key="SliderLabelWidth">20</x:Double>

			<!-- スライダー行の水平スライダーの左右マージン。左がラベルとの隙間、右が数値入力欄との隙間で、全スライダータブの水平スライダーがこれを参照する。各行の Grid は ColumnSpacing を持たず、列間の隙間はこのマージンで一点に集める。 -->
			<Thickness x:Key="SliderRowGap">0,0,12,0</Thickness>
		</ResourceDictionary>
	</Application.Resources>
</Application>
